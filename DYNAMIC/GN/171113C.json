  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "నందనవనంలో దాగిన మొహం 3. శకుని చేతిలోని ఆయుధం"
    },
    {
      "row": 2,
      "number": 5,
      "text": "వని కాని భూమి"
    },
    {
      "row": 3,
      "number": 7,
      "text": "నీటిలోని మొసలి"
    },
    {
      "row": 4,
      "number": 9,
      "text": "రాకావెన్నెల సరిపోగా మిగిలిన ఇంటిపేరు"
    },
    {
      "row": 5,
      "number": 10,
      "text": "విష్ణువైతే యుగాల తరబడి. కమల్ హాసనైతే ఒకేసారి"
    },
    {
      "row": 6,
      "number": 11,
      "text": "అతికఠినమైన శిరోలంకారం"
    },
    {
      "row": 7,
      "number": 12,
      "text": "జలదరింపు"
    },
    {
      "row": 8,
      "number": 13,
      "text": "వనంతో కవిత్వం"
    },
    {
      "row": 9,
      "number": 14,
      "text": "లాలించేచోటు పాలించకపోయినా లోటు లేదు"
    },
    {
      "row": 10,
      "number": 16,
      "text": "విశాఖదత్తుడి గుప్తనాటకం"
    },
    {
      "row": 11,
      "number": 19,
      "text": "ఎంతసేపూ కిచకిచలే"
    },
    {
      "row": 12,
      "number": 21,
      "text": "రాజ్యతంత్రం లేదా మంత్రాంగం"
    },
    {
      "row": 13,
      "number": 23,
      "text": "క్లూనిచ్చే గుర్తు"
    },
    {
      "row": 14,
      "number": 25,
      "text": "మనం చేసే తలపోత"
    },
    {
      "row": 15,
      "number": 26,
      "text": "అంతుచిక్కని వింతదేవుడు"
    },
    {
      "row": 16,
      "number": 27,
      "text": "కవి కలానికి రాజులు కట్టిన వెల"
    },
    {
      "row": 17,
      "number": 31,
      "text": "మధ్యమంతో మొదలుపెట్టి ఆరోహణ అవరోహణాలు పూర్తి"
    },
    {
      "row": 18,
      "number": 34,
      "text": "చెడ్డ గర్వం"
    },
    {
      "row": 19,
      "number": 35,
      "text": "చిలీ దేశపు సముద్రమంత గొప్ప కవి నాయకుడు 36. అక్కడే ఉంది హద్దు"
    },
    {
      "row": 20,
      "number": 37,
      "text": "తలవెంట్రుకల వరుస"
    },
    {
      "row": 21,
      "number": 39,
      "text": "ఇరుగ్గా సర్దుకున్న తిరుచానూరు అమ్మవారు 41. గౌరవం కోసం క్రోసు దూరం వడిగా వెళ్ళు"
    },
    {
      "row": 22,
      "number": 42,
      "text": "శిల్పి"
    },
    {
      "row": 23,
      "number": 43,
      "text": "అడుగులు తడబడ బుడుత(డు) నడిచెనిలా"
    },
    {
      "row": 24,
      "number": 44,
      "text": "ఫుల్ మీల్స్ రాత్రికి తింటారా?"
    },
    {
      "row": 25,
      "number": 45,
      "text": "రీతికి తోడొచ్చే పరభాషా సంప్రదాయం"
    }
  ],
  "downEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "కోరిక తీర్చే వెల్లువ"
    },
    {
      "row": 2,
      "number": 2,
      "text": "శివుడి వాహనం పెరిగితే ఒక పూలచెట్టు"
    },
    {
      "row": 3,
      "number": 3,
      "text": "కువకువలాడే క్వార్టర్ బాటిల్ రమ్"
    },
    {
      "row": 4,
      "number": 4,
      "text": "మడువలేని వటుడు పాలమరకతో పడిన ఆందోళన"
    },
    {
      "row": 5,
      "number": 5,
      "text": "6 నిలువుకు అడ్డమొచ్చేది"
    },
    {
      "row": 6,
      "number": 6,
      "text": "5 నిలువు లేకపోవడం"
    },
    {
      "row": 7,
      "number": 7,
      "text": "రాధ కంట మరల నీరొలకగ శివాయని పిలిచెనట"
    },
    {
      "row": 8,
      "number": 8,
      "text": "ఝంకారం కాదు. నారి చేసే ధ్వని"
    },
    {
      "row": 9,
      "number": 13,
      "text": "పిళ్ళా కనకం తలవాకిట్లో అటు ఇటుగా"
    },
    {
      "row": 10,
      "number": 14,
      "text": "లోపలినుంచి పారే జలం. ఒక ఊరు, ఒక తీర్థం"
    },
    {
      "row": 11,
      "number": 15,
      "text": "చెవికింపైన రాష్ట్రం"
    },
    {
      "row": 12,
      "number": 17,
      "text": "పాకాల్లో అతిసులువైనది"
    },
    {
      "row": 13,
      "number": 18,
      "text": "ఒకరకంగా 15 నిలువు దీనికి సంబంధించినదే"
    },
    {
      "row": 14,
      "number": 20,
      "text": "అడ్డం 1 తల మారిస్తే యుద్ధమే."
    },
    {
      "row": 15,
      "number": 22,
      "text": "ఒకచోట సొంతభక్తితో, ఇంకొకచోట వేరొకరి యుక్తితో"
    },
    {
      "row": 16,
      "number": 23,
      "text": "బేడీ"
    },
    {
      "row": 17,
      "number": 24,
      "text": "26 అడ్డమాయన దీనిని తొలగిస్తాడా?"
    },
    {
      "row": 18,
      "number": 25,
      "text": "ఎటు చూసినా ఒకటే, అయినా దీన్ని తిప్పడం పరువుతక్కువ పని"
    },
    {
      "row": 19,
      "number": 28,
      "text": "రువాండా కాదు ఇంకో దేశపు రాజధాని"
    },
    {
      "row": 20,
      "number": 29,
      "text": "నిగనిగల మధ్య తవ్వకాలు జరిపేచోటు 30. ఉజ్జయినిలో ప్రసిద్ధ దేవాలయం"
    },
    {
      "row": 21,
      "number": 32,
      "text": "దండుమగడు"
    },
    {
      "row": 22,
      "number": 33,
      "text": "ఎల్లప్పుడూ శుభం కలిగించేవాడు (అప్పుడప్పుడూ భయం కూడా)"
    },
    {
      "row": 23,
      "number": 35,
      "text": "చందమామను మింగేవాడు రాహువు"
