    {
      "row": 24,
      "number": 36,
      "text": "కష్టమైన దశ"
    },
    {
      "row": 25,
      "number": 38,
      "text": "వెళ్ళు అమ్మాజీ అంటున్న అల్లుడు"
    },
    {
      "row": 26,
      "number": 39,
      "text": "ఇంగ్లీషు పుండు"
    },
    {
