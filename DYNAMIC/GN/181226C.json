  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "ఆటకు ఇంగ్లీషు “మందు” తిప్పి కలపాలి (3)"
    },
    {
      "row": 2,
      "number": 3,
      "text": "తిరుమల గుడి పురోహితులకి వంశపారంపర్యంగా వచ్చిన హక్కు? (3)"
    },
    {
      "row": 3,
      "number": 5,
      "text": "ఆడ 42 స్త్రీజాతివిశేషము (3)"
    },
    {
      "row": 4,
      "number": 7,
      "text": "మొదట కోతిలా అనిపించినా ఆవు (3)"
    },
    {
      "row": 5,
      "number": 9,
      "text": "చిత్రకారుడు (3)"
    },
    {
      "row": 6,
      "number": 10,
      "text": "ప్రహ్లాదుడి తమ్ముడి కొడుకు (3)"
    },
    {
      "row": 7,
      "number": 11,
      "text": "పేలవంగ కనిపించే దేవకుసుమము (3)"
    },
    {
      "row": 8,
      "number": 12,
      "text": "దీపాలు పెట్టే వేళలో తలతెగితే మంత్రాక్షరాలతో చక్రం వెయ్యాలి (2)"
    },
    {
      "row": 9,
      "number": 13,
      "text": "గోగణంలో ఒకటి (4)"
    },
    {
      "row": 10,
      "number": 15,
      "text": "వరిలా పెరిగే మహాబలుడు (3)"
    },
    {
      "row": 11,
      "number": 16,
      "text": "చుప్పనాతి అప్పుడప్పుడు తిరగబడితే నీట్లో మురికి కనిపిస్తుంది (2)"
    },
    {
      "row": 12,
      "number": 18,
      "text": "మంచివాసన గల ఆవు (3)"
    },
    {
      "row": 13,
      "number": 19,
      "text": "సర్పవిశేషముతో చెవికమ్మా? గంగానది ఘట్టమా? (5)"
    },
    {
      "row": 14,
      "number": 21,
      "text": "తుని పోదుర, కునుకు పెట్టేవాడా? (5)"
