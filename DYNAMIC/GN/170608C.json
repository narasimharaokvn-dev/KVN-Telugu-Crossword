  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "విశ్వనాథ...శాస్త్రి 3. అటుఇటుగా సుత మమ అనుకోవడంలో అనురాగం"
    },
    {
      "row": 2,
      "number": 5,
      "text": "ఇప్పుడే కదా మొదలుపెట్టింది? అప్పుడే ఇక్కడికి చేరామా?"
    },
    {
      "row": 3,
      "number": 7,
      "text": "అరే! దిగ్గున దృష్టినాకర్షించగలిగెనే!"
    },
    {
      "row": 4,
      "number": 9,
      "text": "తృప్తిచెందిన మనసు"
    },
    {
      "row": 5,
      "number": 10,
      "text": "దీనితో మెత్తగా ఒకటంటే చాలు, తిరిగొస్తాయి గట్టిగా రెండు"
    },
    {
      "row": 6,
      "number": 11,
      "text": "అంకుశధారి"
    },
    {
      "row": 7,
      "number": 12,
      "text": "మిక్కిలిగా ఈడేరుటతో వచ్చు కీర్తి"
    },
    {
      "row": 8,
      "number": 13,
      "text": "విజయనగరపు వింతపక్షి."
    },
    {
      "row": 9,
      "number": 15,
      "text": "హిందూమహాసముద్రంలో తెల్లవాడి సైనిక స్థావరం"
    },
    {
      "row": 10,
      "number": 17,
      "text": "మనిషిని పోలిన కోతి"
    },
    {
      "row": 11,
      "number": 19,
      "text": "అంగారవర్ణం"
    },
    {
      "row": 12,
      "number": 21,
      "text": "కురులకు అలంకారం"
    },
    {
      "row": 13,
      "number": 23,
      "text": "వాలి కడుపులో వికటించిన శేఫాలిక"
    },
    {
      "row": 14,
      "number": 24,
      "text": "మరుకండవాడలో వాడలేని జంగమదేవర వాద్యం"
    },
    {
      "row": 15,
      "number": 25,
      "text": "చేసిన తప్పుకు శిక్ష తప్పిం(గ్గిం)చుకునే మార్గం 28. మరులు గొలపడానికి కవనమల్లినవారి మొదటి ఎంపిక"
    },
    {
      "row": 16,
      "number": 31,
      "text": "అడడా ధం, గారాబం నుండి పెనవేసుకున్న అనురాగం"
    },
    {
      "row": 17,
      "number": 32,
      "text": "రాత్రంతా చలి నుంచి కాపాడేవి, రగులుకునే చలిమంటలు కావు"
    },
    {
      "row": 18,
      "number": 33,
      "text": "అడ్డం 34 నుంచి పొందేది"
    },
    {
      "row": 19,
      "number": 34,
      "text": "బజ్జీల బండి కాడ వడివేలు కరకరలాడించేవి"
    },
    {
      "row": 20,
      "number": 36,
      "text": "విన్నవించు"
    },
    {
      "row": 21,
      "number": 38,
      "text": "ఎండాకాలం కదా? బస్తీ అని భాష మార్చి చెప్పినా వేడి తగుల్తూనే ఉంది"
    },
    {
      "row": 22,
      "number": 39,
      "text": "బిడ్డ. విడగొడితే చెడ్డ మృత్యువు"
    },
    {
      "row": 23,
      "number": 40,
      "text": "అష్టసిద్ధుల్లోనొకటి తడబడినట్లనిపించినా స్వరాల వరుసలో సరిగా అమరింది"
    },
    {
      "row": 24,
      "number": 41,
      "text": "కలత"
    }
  ],
  "downEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "క్షీరాన్నం"
    },
    {
      "row": 2,
      "number": 2,
      "text": "నీచ లక్షణం"
    },
    {
      "row": 3,
      "number": 3,
      "text": "మనేద"
    },
    {
      "row": 4,
      "number": 4,
      "text": "తరానికి, తమానికి గల తేడా"
    },
    {
      "row": 5,
      "number": 5,
      "text": "కరతలామలకంలో ఫలమూ పుష్పం ఒకే రూపంలో"
    },
    {
      "row": 6,
      "number": 6,
      "text": "వయ్యారిభామా!"
    },
    {
      "row": 7,
      "number": 7,
      "text": "అది హనుమానుడి గానంలో సందేహాస్పదంగా దాగుంది"
    },
    {
      "row": 8,
      "number": 8,
      "text": "నేటి తర్వాత"
    },
    {
      "row": 9,
      "number": 12,
      "text": "ఫలం పుష్పం"
    },
    {
      "row": 10,
      "number": 13,
      "text": "వీరాధివీర, శూరాధిశూర"
    },
    {
      "row": 11,
      "number": 14,
      "text": "ఇరవైనాలుగుకు మరోరూపు"
    },
    {
      "row": 12,
      "number": 16,
      "text": "యజ్ఞాలు?"
    },
    {
      "row": 13,
      "number": 18,
      "text": "ఇంకో జాలపత్రిక"
    },
    {
      "row": 14,
      "number": 20,
      "text": "చాలా పెద్ద తప్పు"
    },
    {
      "row": 15,
      "number": 21,
      "text": "విహరించువాడు."
    },
    {
      "row": 16,
      "number": 22,
      "text": "పిలుస్తున్నది అర్జునుడినా కొలుస్తున్నది. వరుణుడినా?"
    },
    {
      "row": 17,
      "number": 23,
      "text": "త్రివిక్రమ"
    },
    {
      "row": 18,
      "number": 26,
      "text": "స్వభావాల వర్ణాలు"
    },
    {
      "row": 19,
      "number": 27,
      "text": "ఈ సినిమాటోగ్రాఫర్ ఇంటిపేరు అనుకోలు కాదు, అసలుపేరు గిరి కాదు."
    },
    {
      "row": 20,
      "number": 29,
      "text": "మమకారం, వినోదం, ఆవేశం, ఇత్యాదులన్నీ దీనికి ఉదాహరణలే"
    },
    {
      "row": 21,
      "number": 30,
      "text": "వెయ్యక తీరదు, తీసివెయ్యక తప్పదు"
    },
    {
      "row": 22,
      "number": 32,
      "text": "రమతో వినోదించువాడు"
    },
    {
      "row": 23,
      "number": 33,
      "text": "గంధం వస్త్రసంబంధ స్వభావం"
    },
    {
      "row": 24,
      "number": 35,
      "text": "అల్లరి చేయుటెరుగని లేతకొమ్మ"
    },
    {
      "row": 25,
      "number": 36,
      "text": "అంచు కరిగిన మంచు, భూమితో కలిసి చేసిన మాయ"
    },
    {
      "row": 26,
      "number": 37,
      "text": "వేచి ఉండే సమయం పెరిగే కొద్దీ క్షణాలిలా మారుతాయి"
    }
  ]
}