  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "ఒకటికి రెండైతే కన్నుపొడుచుకుని చూడండి, ఏమైనా కనిపిస్తుందేమో (6)"
    },
    {
      "row": 2,
      "number": 3,
      "text": "హిందీ సినిమాల ఖిలాడీహీరో యొక్క స్వర్గము (6)"
    },
    {
      "row": 3,
      "number": 6,
      "text": "పద్యం మొదలు ప్రయత్నించేవాడు ఋషి (2)"
    },
    {
      "row": 4,
      "number": 8,
      "text": "స్వర్గమే అని తేల్చి చెప్పాలా? (2)"
    },
    {
      "row": 5,
      "number": 10,
      "text": "చివర నెపంతో రెప్ప వేయకుండా చూస్తే తెలుస్తుంది మీనులో దివిజులో (4)"
    },
    {
      "row": 6,
      "number": 12,
      "text": "పిల్లకాలువల ఉపమామనది (4)"
    },
    {
      "row": 7,
      "number": 14,
      "text": "పూర్వాపరాలు చూచీ చూడకుండా భరోసాలిస్తే కుత్తుకకంటగలదు, జాగ్రత్త (4)"
    },
    {
      "row": 8,
      "number": 15,
      "text": "ఆనందకరము అన్నమయ్య (4)"
    },
    {
      "row": 9,
      "number": 16,
      "text": "చివర లేని కలతపడు (3)"
    },
    {
      "row": 10,
      "number": 18,
      "text": "దగ్గరి కన్ను వేదాధ్యయనమునకు చేయు సంస్కారవిశేషము (6)"
    },
    {
      "row": 11,
      "number": 19,
      "text": "లచ్చిందేవి జనకుడు (6)"
    },
    {
      "row": 12,
      "number": 22,
      "text": "చెడ్డవాడు కావేరి కాదు (3)"
    },
    {
      "row": 13,
      "number": 24,
      "text": "ఏమిది? కళింగాంధ్రమా? (2)"
    },
    {
      "row": 14,
      "number": 26,
      "text": "మనసరసిజయుడా మరుడు (4)"
    },
    {
      "row": 15,
      "number": 28,
      "text": "అటునుంచి ముఖం పైన కాదు, పారశీక సమక్షంలో (అటు మీసమక్షంలో ఆమోదమేకద) (4)"
    },
    {
      "row": 16,
      "number": 30,
      "text": "కొండనితిప్పలేము కనక కొండదొరని తిప్పండి (4)"
    },
    {
      "row": 17,
      "number": 32,
      "text": "అరకలు విసిరిన సగంపువ్వు (4)"
    },
    {
      "row": 18,
      "number": 34,
      "text": "చోరధనం లోపించినది (2)"
    },
    {
      "row": 19,
      "number": 36,
      "text": "చివర కత్తిరిస్తే యముడు పావువంతా? (2)"
    },
    {
      "row": 20,
      "number": 37,
      "text": "సీతారామశాస్త్రి గారు మీటిన తూరుపువీణ (6)"
    },
    {
      "row": 21,
      "number": 38,
      "text": "కొరోన వలన యానములేక రెక్కలుముడుచుకున్న ఆధునిక పక్షులు (6)"
    }
  ],
  "downEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "అంబగతి గౌరి (2)"
    },
    {
      "row": 2,
      "number": 2,
      "text": "తమ అర్జననిచూపుడు (3)"
    },
    {
      "row": 3,
      "number": 4,
      "text": "యోచనా, కమల - (3)"
    },
    {
      "row": 4,
      "number": 5,
      "text": "మొదలులేక ముసలిదైన వెన్నెల (2)"
    },
    {
      "row": 5,
      "number": 6,
      "text": "ఈ మహాపట్నం యముడిదా? (6)"
    },
    {
      "row": 6,
      "number": 7,
      "text": "తలలేని అర్జునుడి అంజనమే నాగారి (6)"
    },
    {
      "row": 7,
      "number": 9,
      "text": "వడి గల టి.నగర్ చెన్నపట్నానిదా? అమరలోకానిదా? (6)"
    },
    {
      "row": 8,
      "number": 10,
      "text": "అటూ ఇటూ అయినా సంపూర్ణముగా స్వచ్ఛమైనది (4)"
    },
    {
      "row": 9,
      "number": 11,
      "text": "విశాఖలో ఒత్తు షరామాములుగా భాగస్వామ్యం (4)"
    },
    {
      "row": 10,
      "number": 12,
      "text": "పోల్చదగినదే, తినతగ్గది కాదు (4)"
    },
    {
      "row": 11,
      "number": 13,
      "text": "విరిసెనటదిగో మనశిరీషము (4)"
    },
    {
      "row": 12,
      "number": 16,
      "text": "ధనముకోరి పడతి (3)"
    },
    {
      "row": 13,
      "number": 17,
      "text": "లేతదేకాని ఉసిరి కాదు (3)"
    },
    {
      "row": 14,
      "number": 20,
      "text": "అటు తిరిగిన ఆడకర్కటం (2)"
    },
    {
      "row": 15,
      "number": 21,
      "text": "పొగడపచ్చఫణములుపదినూర్లు (6)"
    },
    {
      "row": 16,
      "number": 23,
      "text": "జయను భారతంగా మార్చినవాడు (6)"
    },
    {
      "row": 17,
      "number": 25,
      "text": "పదివారాలు ఆత్రములిటు సతతముపడనేల? (6)"
    },
    {
      "row": 18,
      "number": 26,
      "text": "ఇలా నిండు నూరేళ్ళు జీవించాలన్నది దీవన (4)"
    },
    {
      "row": 19,
      "number": 27,
      "text": "సీరియల్ పూర్తిగా అర్ధమవాలంటే ఈ కథకూడా చెప్పాలి (4)"
    },
    {
      "row": 20,
      "number": 28,
      "text": "అటునుంచి చిన్నబోయిన గోతతి (4)"
    },
    {
      "row": 21,
      "number": 29,
      "text": "ఇటీవల వివాదస్పదమైన మంగ్లీ పాటలో పరపతి గలవాడు (4)"
    },
    {
      "row": 22,
      "number": 31,
      "text": "దశతిరిగినపప్పు (3)"
    },
    {
      "row": 23,
      "number": 33,
      "text": "పింగళి వారి దృష్టిలో ఇది కూడా సుఖం కాదా? (3)"
    },
    {
      "row": 24,
      "number": 35,
      "text": "తలకిందులైన అవాప్తం (2)"
    },
    {
      "row": 25,
      "number": 36,
      "text": "పద్యానిదైతే పాదం, మనదైతే ఇదే (2)"
    }
  ]
