  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "మకరిని సరిచేసి సొరుగు చివర పెట్టు. ఇంకా సందేహమా? (5)"
    },
    {
      "row": 2,
      "number": 3,
      "text": "రౌతు (3)"
    },
    {
      "row": 3,
      "number": 5,
      "text": "బావలు కల వనితాపక్షపత్రిక (5)"
    },
    {
      "row": 4,
      "number": 7,
      "text": "యోగాసనమనుకోకు, పాలేటిపట్టి (5)"
    },
    {
      "row": 5,
      "number": 9,
      "text": "జాతీయ పురస్కారం పొందిన వాహినీవారి చిత్రరాజము (5)"
    },
    {
      "row": 6,
      "number": 11,
      "text": "కాళిదాసుకు, పెద్దన్నకు, కృష్ణశాస్త్రికి, శ్రీశ్రీకి తెలిసిన ఈ రహస్యం తెలుగులో (5)"
    },
    {
      "row": 7,
      "number": 12,
      "text": "వనరుహము ముందు విలపించు (3)"
    },
    {
      "row": 8,
      "number": 13,
      "text": "భేతాళుడు (5)"
    },
    {
      "row": 9,
      "number": 15,
      "text": "వెట్టకంటి (5)"
    },
    {
      "row": 10,
      "number": 17,
      "text": "పిసినిగొట్టు (5)"
    },
    {
      "row": 11,
      "number": 20,
      "text": "భూమిని తిరగేస్తే వేడిని నాశనం చేసే పాలకూర (2)"
    },
    {
      "row": 12,
      "number": 21,
      "text": "లోక నరేంద్ర వంశ దహనా! (2) -"
    },
    {
      "row": 13,
      "number": 22,
      "text": "పరీధావికి నిరుడు (5)"
    },
    {
      "row": 14,
      "number": 24,
      "text": "శ్రీరాముని చరితమును తెలుపుతూ లవకుశులు తీసిన రాగం (5)"
    },
    {
      "row": 15,
      "number": 26,
      "text": "ఇల్లాలులేని ఇల్లు. అని ఒక సామెత (5)"
    },
    {
      "row": 16,
      "number": 28,
      "text": "సురభారతిలో స్ఫటికంలా ప్రకాశించు స్వభావం కలవాడు (3)"
    },
    {
      "row": 17,
      "number": 29,
      "text": "స్వరాలతో నాట్యమాడే పిల్లనగ్రోవి (5)"
    },
    {
      "row": 18,
      "number": 31,
      "text": "హెల్మెట్ అద్దం (5)"
    },
    {
      "row": 19,
      "number": 32,
      "text": "అధిష్టానాన్ని ఎదురించి మాట్లాడటాన్ని ఇది వినిపిస్తున్నారంటారు (5)"
    }
