  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "బలం విశేషంగా బోల్తాపడి జాగుకు కారణమైంది 3. సవరణ చేస్తే చక్కనౌతుంది"
    },
    {
      "row": 2,
      "number": 5,
      "text": "శ్రీశ్రీ సాక్షిగా ఊరికే"
    },
    {
      "row": 3,
      "number": 7,
      "text": "కలం కవి మీద తిరగబడి చెదిరిపోయింది"
    },
    {
      "row": 4,
      "number": 9,
      "text": "హారతవడంలో పద్ధతి"
    },
    {
      "row": 5,
      "number": 10,
      "text": "వాహనం కాదు. గర్భగుడి పైకప్పు మీదుండేది"
    },
    {
      "row": 6,
      "number": 11,
      "text": "ఒక దేశమంత పెద్ద ఇల్లు"
    },
    {
      "row": 7,
      "number": 12,
      "text": "కవి రమ్యంగా వర్ణించదగిన కంచుకం"
    },
    {
      "row": 8,
      "number": 13,
      "text": "ముక్కంటి"
    },
    {
      "row": 9,
      "number": 14,
      "text": "ఇక్కడి మాన్యాలు ఎవరికీ కాబట్టవు"
    },
    {
      "row": 10,
      "number": 16,
      "text": "ఆంధ్రమహాభారతకర్తలు"
    },
    {
      "row": 11,
      "number": 19,
      "text": "విజయా వారి ప్రొడక్షను. పేరే కాదు సినిమా కూడా పెద్దదే."
    },
    {
      "row": 12,
      "number": 21,
      "text": "దగ్గరికొచ్చా"
    },
    {
      "row": 13,
      "number": 23,
      "text": "23 నిలువు కుదరకపోవడం"
    },
    {
      "row": 14,
      "number": 25,
      "text": "ఒక కట్టడం, ఒక సాధనం"
    },
    {
      "row": 15,
      "number": 26,
      "text": "డుతుసుద్రీమా"
    },
    {
      "row": 16,
      "number": 27,
      "text": "అడ్డం 19తో కలిసి సామెత సంపూర్ణం"
    },
    {
      "row": 17,
      "number": 31,
      "text": "పింగాణీ పాత్రలు తయారుచేసే మట్టి"
    },
    {
      "row": 18,
      "number": 34,
      "text": "కుమార భీమేశ్వరుడి ఆరామం"
