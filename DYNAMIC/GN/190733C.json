  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "కీకారణ్యానికైనా, జనారణ్యానికైనా తిండి కావాలంటే జరిగి తీరాల్సిందే (10)"
    },
    {
      "row": 2,
      "number": 6,
      "text": "ఈ మూడు బేడలు వేదాల్లోవా?(4)"
    },
    {
      "row": 3,
      "number": 9,
      "text": "అన్యభాషలో చూస్తే లోపమే(2)"
    },
    {
      "row": 4,
      "number": 10,
      "text": "అదిగదిగోనావనునడుపును (3)"
    },
    {
      "row": 5,
      "number": 11,
      "text": "అలవైకుంఠ పురములోనూ ఎగురుతుంది, ఉందిగా పాల్కడలి (2)"
    },
    {
      "row": 6,
      "number": 12,
      "text": "విపరీతభావమీ అవమానం (4)"
    },
    {
      "row": 7,
      "number": 14,
      "text": "ఆబాల గోపాల క్యాబలి.. చిన్నపిల్లలవే (4)"
    },
    {
      "row": 8,
      "number": 18,
      "text": "దున్నపోతును ఈ తాడుతో కట్టేసి తిరగేయండి (4)"
    },
    {
      "row": 9,
      "number": 19,
      "text": "తిలాలోలకము లలాటమునకా (4)"
    },
    {
      "row": 10,
      "number": 20,
      "text": "మాపోలిక. ఎట్లు? (2)"
    },
    {
      "row": 11,
      "number": 22,
      "text": "కడుపునిండువరకునమలు (3)"
    },
    {
      "row": 12,
      "number": 24,
      "text": "రమ్మన్న రామన్న ఆపడు (2)"
    },
    {
      "row": 13,
      "number": 25,
      "text": "శ్రీ శ్రీ కవితకువికారమైనదేది? (7)"
    },
    {
      "row": 14,
      "number": 26,
      "text": "ఇక చాలనిధిక్కరిస్తే హాయా? (7)"
    },
    {
      "row": 15,
      "number": 27,
      "text": "చెవితో వినండీపండుని (2)"
    },
    {
      "row": 16,
      "number": 28,
      "text": "తిరగబడి విసుగును చూపాలా? (3)"
    },
    {
      "row": 17,
      "number": 30,
      "text": "నిదురలేచిన అందంలేనిదెప్పుడు (2)"
    },
    {
      "row": 18,
      "number": 31,
      "text": "రానివాడు కాదు- (4)"
    },
    {
      "row": 19,
      "number": 33,
      "text": "అతిగావినుమరి పధ్నాలుగునాటి పున్నమ (4)"
    },
    {
      "row": 20,
      "number": 35,
      "text": "మతిలేక తిరిగిన అందమా, మందునిది? (4)"
    },
    {
      "row": 21,
      "number": 36,
      "text": "ఒకదినుసు కాదు, అన్నీ (4)"
    },
    {
      "row": 22,
      "number": 37,
      "text": "పెద్దది కదా! అట్నుంచైనా అక్కర లేదు (2)"
    },
    {
      "row": 23,
      "number": 39,
      "text": "మతపు కమతంలో ప్రేమ పండుతుందా? (3)"
    },
    {
      "row": 24,
      "number": 41,
      "text": "ఆనుపానులెరిగి పూను (2)"
    },
    {
      "row": 25,
      "number": 42,
      "text": "కాకరూకమునకు, కాకమునకు తగినదేనా? (9)"
    },
    {
      "row": 26,
      "number": 43,
      "text": "అజుడు-బ్రహ్మ, బాణుడు - సుమశరుడు, మరి సూర్యుడు? (5) నిలువు"
    }
  ],
  "downEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "ఉమ్మితే తప్పు, వాడక పోతే తుప్పు (3)"
    },
    {
      "row": 2,
      "number": 2,
      "text": "గీరు (2)"
    },
    {
      "row": 3,
      "number": 3,
      "text": "తిరగేసిన బాధకి వత్తు లేదు (2)"
    },
    {
      "row": 4,
      "number": 4,
      "text": "మధ్వన జగమములు రాయబారులా? (7)"
    },
    {
      "row": 5,
      "number": 5,
      "text": "తిన్ననైనవాడు కాదు, అందుకే తిరగబడ్డాడు (2)"
    },
    {
      "row": 6,
      "number": 7,
      "text": "ఆరడ్డంలో ఒకటి తిరగబడింది(2)"
    },
    {
      "row": 7,
      "number": 8,
      "text": "కిందనించైనా కంటేనే వస్తాయి (3)"
    },
    {
      "row": 8,
      "number": 12,
      "text": "అపరాహ్నవేళ పతాకస్థాయిలో చుట్టుకొన్నదా (4)"
    },
    {
      "row": 9,
      "number": 13,
      "text": "బాసుమతి బియ్యమైనా పండవలసిన చోటిదే (4)"
    },
    {
      "row": 10,
      "number": 14,
      "text": "ఒక చేత బడిశపట్టి మరోక చేత మతిలేక బాణాలు వేయుటెట్లు (4)"
    },
    {
      "row": 11,
      "number": 15,
      "text": "గానుగపిండి గల వ్రాత (4)"
    },
    {
      "row": 12,
      "number": 16,
      "text": "ఈకలు పక్షికా, జంతువుకా? క గుణింతంతో చెప్పండి (11)"
    },
    {
      "row": 13,
      "number": 17,
      "text": "మీ అన్నైనా, నాన్ననైనా అనేది నిన్నే.. నాగుణింతముతో నాణ్యంగా (11)"
    },
    {
      "row": 14,
      "number": 21,
      "text": "ఈ అమ్మవారి కళ్ళందాలు మల్లెచిన్నాలు (3)"
    },
    {
      "row": 15,
      "number": 22,
      "text": "మసుకుచీకట్లో అటూ ఇటూగా వికసించిందా? (3)"
    },
    {
      "row": 16,
      "number": 23,
      "text": "మాను మాకయితేనే రాగాలు పలకడం (3)"
    },
    {
      "row": 17,
      "number": 24,
      "text": "మధ్యవత్తున్న వదిన (3)"
    },
    {
      "row": 18,
      "number": 29,
      "text": "అందామయా, ఆనందంగా ఉందామయా అన్నారు పెద్దమనుషులు( 7)"
    },
    {
      "row": 19,
      "number": 31,
      "text": "సఫలమైన వ్రతానికి వేదం (4)"
    },
    {
      "row": 20,
