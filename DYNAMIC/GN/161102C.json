{
  "sheetName": "161102",
  "identity": "161102C",
  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "కసరత్తు సరిపాళ్ళతో పిండి కలిపితే అమ్మవారి నైవేద్యం రెడీ! (4)"
    },
    {
      "row": 2,
      "number": 3,
      "text": "చంచలనేత్ర నడుము తడబడింది (4)"
    },
    {
      "row": 3,
      "number": 6,
      "text": "వేరే ప్రశంస సరే, తీసి చూడు లోపలికి మార్గం కనిపిస్తుంది (3)"
    },
    {
      "row": 4,
      "number": 9,
      "text": "రావి విశాలాక్షి కట్టుకోవాలని కోరుకున్నది (8)"
    },
    {
      "row": 5,
      "number": 13,
      "text": "ఈ గీతని మోయడమంటే గాయపడటమేనట! (2)"
    },
    {
      "row": 6,
      "number": 14,
      "text": "ఇది ద్విరుక్తమైతే పనులు తొందరగా జరుగుతాయి (2)"
    },
    {
      "row": 7,
      "number": 15,
      "text": "చాలా వెనక్కి తిరిగింది! (2)"
    },
    {
      "row": 8,
      "number": 17,
      "text": "తప్పిదం మొదటే మడతపడింది (2)"
    },
    {
      "row": 9,
      "number": 18,
      "text": "వేంకటగిరిలో నెలకొన్న రాజ్యం (2)"
    },
    {
      "row": 10,
      "number": 19,
      "text": "సోదరి సోదరుని సోదరుడు ఎవరో మా తానీషాగారికి తెలుసు (3)"
    },
    {
      "row": 11,
      "number": 20,
      "text": "ఒక పురుగు విషం కూడా శుభమే (1)"
    },
    {
      "row": 12,
      "number": 21,
      "text": "కింద క్యా హై? శిరసే హై! (2)"
    },
    {
      "row": 13,
      "number": 23,
      "text": "పూర్వం మొదలు తుది ఒకటే (2)"
    },
    {
      "row": 14,
      "number": 25,
      "text": "మహాసముద్రాల అనుసంధానమే మా పనా? (3)"
    },
    {
      "row": 15,
      "number": 26,
      "text": "పోవుండే చోటు తెలియాలా? ఈ తోటకి పొల్లు చేరిస్తే సరి! (3)"
    },
    {
      "row": 16,
      "number": 27,
      "text": "ఇంటిపైన కమ్ముకొనే నల్లని చీకటిలో టీ తాగుదాం (2)"
    },
    {
      "row": 17,
      "number": 28,
      "text": "వద్దన్నా చిటపటలాడుతూ వస్తుంది (3)"
    },
    {
      "row": 18,
      "number": 29,
      "text": "ఓపలేము మము ఆద్యంతమూ రక్షించు! (2)"
    },
    {
      "row": 19,
      "number": 30,
      "text": "జారిన కల చుట్టూ వలపన్నడం పూర్తయిందా? (2)"
    },
    {
      "row": 20,
      "number": 32,
      "text": "ఈ రోజులలో నేరాలే ఉండవట! (10)"
    }
  ],
  "downEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "నేపాళ మాంత్రికుని ప్రాణదాత (5)"
    },
    {
      "row": 2,
      "number": 2,
      "text": "దీనర్థం త్రవ్వుచు అనుకునేరు! కాదు, కిందకి వచ్చుచు (3)"
    },
    {
      "row": 3,
      "number": 4,
      "text": "చీ! ఈ నాయకునితో కలిస్తే కక్కుర్తి తప్పదు! (3)"
    },
    {
      "row": 4,
      "number": 5,
      "text": "తొందరగా ప్రవహించే నది (2)"
    },
    {
      "row": 5,
      "number": 7,
      "text": "ఇంకొక రూటే (2)"
    },
    {
      "row": 6,
      "number": 8,
      "text": "ఈ పర్వతభూములను పడితే శివశివా! ఇక అంతే సంగతులు! (9)"
    },
    {
      "row": 7,
      "number": 10,
      "text": "20 అడ్డంతో కలిసి మాయమైపోతున్న మనిషిని వెతకండి (2)"
    },
    {
      "row": 8,
      "number": 11,
      "text": "శీర్షాసనం వేసిన చిన్నది (2)"
    },
    {
      "row": 9,
      "number": 12,
      "text": "9 అడ్డానికి శాస్త్రిగారు ఏమవుతారు? (4)"
    },
    {
      "row": 10,
      "number": 16,
      "text": "వయోలిన్ వాయించడానికి రమ్మనాలా? (3)"
    },
    {
      "row": 11,
      "number": 17,
      "text": "అచ్చమైన తెలుగు కురింటి కవి, సోదరుని కోల్పోయాడు (7)"
    },
    {
      "row": 12,
      "number": 22,
      "text": "ప్రాలేయపథములో కరిగింది భూసురుని మనసు కాదు... (3)"
    },
    {
      "row": 13,
      "number": 23,
      "text": "సముద్రం సమగ్రంగా, ప్రథమావిభక్తితో సహా, తిరగబడింది (5)"
    },
    {
      "row": 14,
      "number": 24,
      "text": "సాయంకాలం breakfast ఏమిటో అడుగుతారా? (3)"
    },
    {
      "row": 15,
      "number": 28,
      "text": "సన్నబడి పట్టుబడింది (3)"
    },
    {
      "row": 16,
      "number": 30,
      "text": "నిజామింట్లో ఉత్తరాంధ్ర ఊరు (2)"
    },
    {
      "row": 17,
      "number": 31,
      "text": "బాణం పొడవైనదే (2)"
    }
  ]
}