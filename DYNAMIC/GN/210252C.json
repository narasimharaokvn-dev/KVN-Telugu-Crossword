{
  "sheetName": "210252",
  "identity": "210252C",
  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "సోమదేవుని సంస్కృత రచన. మొదటి భాగం అలవాటులో పొరపాటుగా త్వరపడి కంచికి వెళ్ళి పోయింది. (6)"
    },
    {
      "row": 2,
      "number": 5,
      "text": "ఓమము, దర్భలు అని కనిపిస్తున్నా, ఇవి ఒక రకం వడ్లు నిజానికి. (6)"
    },
    {
      "row": 3,
      "number": 8,
      "text": "కష్టమే, అందుకని కదిలిపోయింది పాపం. (3)"
    },
    {
      "row": 4,
      "number": 9,
      "text": "రెమ్మలని తెలంగాణలో ఇలా అంటారు (3)"
    },
    {
      "row": 5,
      "number": 10,
      "text": "అటువైపు అందమైన కన్నులు గల స్త్రీ (3)"
    },
    {
      "row": 6,
      "number": 11,
      "text": "ఈ చెట్టు విశ్వనాథ రచన (3)"
    },
    {
      "row": 7,
      "number": 12,
      "text": "పోటీని ఇచ్చేవాడు అందుకని ఎదురు నుంచి వచ్చాడు (4)"
    },
    {
      "row": 8,
      "number": 14,
      "text": "నాగలితో కలిగే ఐశ్వర్యం (4)"
    },
    {
      "row": 9,
      "number": 16,
      "text": "ఇంద్రుడి శంఖము. (2)"
    },
    {
      "row": 10,
      "number": 17,
      "text": "సినిమా పోస్టర్ల రూపురేఖలు మార్చిన ప్రింటింగ్ ప్రెస్ లు. పాత పడ్డాయి కదా చిన్న పోయింది (2)"
    },
    {
      "row": 11,
      "number": 18,
      "text": "శంకర విరచిత శిరోభూషణం (7)"
    },
    {
      "row": 12,
      "number": 19,
      "text": "మరచెంబులో మందారపూల కథకురాలు (7)"
    },
    {
      "row": 13,
      "number": 21,
      "text": "మన్మథుడి వాహనం (6)"
    },
    {
      "row": 14,
      "number": 24,
      "text": "ఈనాటి రాజకీయ నాయకులకు ఈ ఆడంబరము ఎక్కువైపోయింది, చేతల కంటే. (6)"
    },
    {
      "row": 15,
      "number": 27,
      "text": "జమా ఖర్చుల పట్టి అట్నుంచి (3)"
    },
    {
      "row": 16,
      "number": 28,
      "text": "తన అభిప్రాయమేదో తనది. మన అభిప్రాయమసలే పడదోయ్! (3)"
    },
    {
      "row": 17,
      "number": 29,
      "text": "పావలా చిల్లరలో దాక్కున్న పాదం (3)"
    },
    {
      "row": 18,
      "number": 30,
      "text": "ద్రుతంలేని తృతీయా విభక్తి ప్రత్యయాలు (3)"
    },
    {
      "row": 19,
      "number": 31,
      "text": "కుమారుడు (4)"
    },
    {
      "row": 20,
      "number": 33,
      "text": "3 నిలువు అభరణం నుండి పుట్టిందా? (4)"
    },
    {
      "row": 21,
      "number": 35,
      "text": "మండుతున్న పావు భాగం (2)"
    },
    {
      "row": 22,
      "number": 36,
      "text": "మొదటి సినిమాతో మొదటి సినిమా చేసిన హీరోయిన్ ఇంటి పేరు (2)"
    }
  ],
  "downEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "కందుకూరు వారు నడిపిన పత్రిక ఇది (6)"
    },
    {
      "row": 2,
      "number": 2,
      "text": "కత్తి పిడిని పట్టుకున్నటలో నేర్పరి (3)"
    },
    {
      "row": 3,
      "number": 3,
      "text": "మూడు కన్నుల వాడి పత్ని (6)"
    },
    {
      "row": 4,
      "number": 4,
      "text": "మధు అనే రాక్షసుని సంహరించినవాడు (7)"
    },
    {
      "row": 5,
      "number": 5,
      "text": "హరి హరి! ఓ సారి గుంపులు గుంపులుగా సాహంకారముగా! (6)"
    },
    {
      "row": 6,
      "number": 6,
      "text": "వాపోయిన సైరంధ్రి (3)"
    },
    {
      "row": 7,
      "number": 7,
      "text": "అటునుండి అచ్చతెలుగు ఆగమాలు (6)"
    },
    {
      "row": 8,
      "number": 10,
      "text": "అష్ట గణపతులు లో ఓ గణపతిని శీఘ్రంగా పిలవండి (2)"
    },
    {
      "row": 9,
      "number": 11,
      "text": "తల తెగిన దువ్వెన (2)"
    },
    {
      "row": 10,
      "number": 13,
      "text": "తెల్లనిది, నల్లనిది కిందనుంచి (2)"
    },
    {
      "row": 11,
      "number": 15,
      "text": "బంగారు, ఇంద్రుడు (2)"
    },
    {
      "row": 12,
      "number": 20,
      "text": "గడినుడి రచయిత్రి చెప్పిన కథలు (7)"
    },
    {
      "row": 13,
      "number": 21,
      "text": "లక్క ఇంటిని కట్టిన స్థలం పేరు (6)"
    },
    {
      "row": 14,
      "number": 22,
      "text": "అచ్చతెలుగు పేరున్న హైదరాబాద్ క్రికెటర్ ఇంటి పేరు కిందనుంచి (3)"
    },
    {
      "row": 15,
      "number": 23,
      "text": "దురద పెడుతున్న చేతులు, మొలకలు అయ్యాయి (6)"
    },
    {
      "row": 16,
      "number": 24,
      "text": "మాటలతో విశేషమైన విచారణ (6)"
    },
    {
      "row": 17,
      "number": 25,
      "text": "అల్పుడెప్పుడు పలుకే దానిలో ఉన్న బడాయి (3)"
    },
    {
      "row": 18,
      "number": 26,
      "text": "అటునుండి శ్రీశ్రీ కట్టిన ప్రదీప్తకీలల ప్రవాళమాల (6)"
    },
    {
      "row": 19,
      "number": 29,
      "text": "పల్లె, పాటి నేల (2)"
    },
    {
      "row": 20,
      "number": 30,
      "text": "చివరకు చిక్కిన హిందుస్తానీ చిలక (2)"
    },
    {
      "row": 21,
      "number": 32,
      "text": "తేనె, ఈ పాలు అంటే చాలా మందికి ఇష్టం (2)"
    },
    {
      "row": 22,
      "number": 34,
      "text": "దయ (2)"
    }
  ]
