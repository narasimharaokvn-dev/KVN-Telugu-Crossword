{
  "sheetName": "190935",
  "identity": "190935C",
  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "శివుడు స్త్రీల నగలకు చేయి చాపుతాడు (5)"
    },
    {
      "row": 2,
      "number": 3,
      "text": "తలకొట్టి దీర్ఘం తీస్తే పాసురాలు వేలుపులే కదూ (3)"
    },
    {
      "row": 3,
      "number": 5,
      "text": "అటు ఎదురుకునుడు ఏరువాకే (5)"
    },
    {
      "row": 4,
      "number": 9,
      "text": "తాను వదిలిన మునులు గోవులా? (3)"
    },
    {
      "row": 5,
      "number": 10,
      "text": "అజన్మమునకాకాంక్ష సహజమే! దొరకడమే దుర్లభం (5)"
    },
    {
      "row": 6,
      "number": 11,
      "text": "మందారమునా మరందములే అమరికతిరిగిందంతే (5)"
    },
    {
      "row": 7,
      "number": 12,
      "text": "అమరికపట్ల ఒక రకమైన సందేహమా?నాకూ అంతే (5)"
    },
    {
      "row": 8,
      "number": 14,
      "text": "భ్రాంతికి తావులేని పోతపోసిన తెలుగు బంగారం (6)"
    },
    {
      "row": 9,
      "number": 15,
      "text": "చెకుముకి తోటిదే టిట్టిభము (6)"
    },
    {
      "row": 10,
      "number": 16,
      "text": "ఈ పటములు వదలం. అదే మానుష జన్మం (5)"
    },
    {
      "row": 11,
      "number": 18,
      "text": "కత్తిలా ఉండే నెలరేని నవ్వు (5)"
    },
    {
      "row": 12,
      "number": 20,
      "text": "కపిదీరక మైన కాగడా (5)"
    },
    {
      "row": 13,
      "number": 23,
      "text": "సున్నాలు తేలిగ్గా కొట్టండి, ధరలు తక్కువ (3)"
    },
    {
      "row": 14,
      "number": 25,
      "text": "ఇది పదములదా? అన్నారు సిరివెన్నెల. అటునించి ఒక్కటే మోగినా సవ్వడి? (5)"
    },
    {
      "row": 15,
      "number": 26,
      "text": "తళుకు బెళుకులకి నగలే అక్కర్లేదుట (3)"
    },
    {
      "row": 16,
      "number": 27,
      "text": "ముకురమునున్న రాక్షసుని దునిమినవాడు (5)"
    }
  ],
  "downEntries": [
    {
      "row": 1,
      "number": 7,
      "text": ",8,22,24. పని చేయిస్తాడని పూజించే ప్రథముడికీ పేరా?"
    },
    {
      "row": 2,
      "number": 1,
      "text": "నీతి నవశతకము వేడికి కరిగిపోతుందా? (6)"
    },
    {
      "row": 3,
      "number": 2,
      "text": "అలసి అటుతిరిగి, ముఖచిత్రవిందుకున్నాడుడు, మాంధాతగారి అబ్బాయికి చివరి అక్షరం నత్తి (6)"
    },
    {
      "row": 4,
      "number": 4,
      "text": "శమదమములనణచే త్యాగరాజుగారి సురాకుమారుడు కిందనించి వచ్చినా కనకమయుడే (7)"
    },
    {
      "row": 5,
      "number": 5,
      "text": "నీ తలలో అవకరము, భూమిమీద (6)"
    },
    {
      "row": 6,
      "number": 6,
      "text": "జామను అశరుడును వెనుతిరిగిన నిశాచరుడే (6)"
    },
    {
      "row": 7,
      "number": 7,
      "text": "మహిమ చూపని కర్మ (2)"
    },
    {
      "row": 8,
      "number": 8,
      "text": "ఎకారము తగిలించుకున్న మెగాస్టార్ ముద్దుపేరు (2)"
    },
    {
      "row": 9,
      "number": 12,
      "text": "దావా వెయ్యని అటువంటి మంటే (3)"
    },
    {
      "row": 10,
      "number": 13,
      "text": "కనులలో ఎగిసే అలలు (3)"
    },
    {
      "row": 11,
      "number": 17,
      "text": "పాటసులభముగపండునది, జ్యోతులవరస (7)"
    },
    {
      "row": 12,
      "number": 18,
      "text": "మేకచంపకదళితము, గొప్ప నైవేద్యఫలము (6)"
    },
    {
      "row": 13,
      "number": 19,
      "text": "సమము. ఆలోకితముల తోడి దృష్టిక్రియ, కిందనించి (6)"
    },
    {
      "row": 14,
      "number": 20,
      "text": "భాసించే మనకతల సావిత్రుడు (6)"
    },
    {
      "row": 15,
      "number": 21,
      "text": "మరకలకలము? చేతి అందము (6)"
    },
    {
      "row": 16,
      "number": 22,
      "text": "పసుపురంగు గగుర్పాటు, విపులంగా చెప్పాలా? (2)"
    },
    {
      "row": 17,
      "number": 24,
      "text": "దొరకునా ఇటువంటి గొప్పవాడి సేవ (2)"
    }
  ]
}