  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "తూర్పునుండి పడమరకు చూస్తే సహవాసాల దోషమని తెలుస్తుంది."
    },
    {
      "row": 2,
      "number": 5,
      "text": "గ్రీకు అక్షరం. తెలుగయితే మీద?"
    },
    {
      "row": 3,
      "number": 7,
      "text": "భైరవయ్య కావ్యం"
    },
    {
      "row": 4,
      "number": 8,
      "text": "ఆరుకు అధ్యక్షుడు"
    },
    {
      "row": 5,
      "number": 9,
      "text": "తెలుగు సినీహీరో “చిరు”నామా!"
    },
    {
      "row": 6,
      "number": 11,
      "text": "రెండుకు ప్రాస! మృత్యువును జయించేదంటారు. 12. మహర్షులు పెంచుకొనేది; ఆడపిల్లలు అల్లుకునేది 13. కన్నడంలో సున్నా! ఇటీవల తెలుగు కవిత్వంలో కూడా ఇది శూన్యం."
    },
    {
      "row": 7,
      "number": 14,
      "text": "హుతభుక్కు - వధూవల్లభుడు. అందుకే వల్లభులనే బహువచనం చేయకూడదు."
    },
    {
      "row": 8,
      "number": 15,
      "text": "నియమాలు (ఎంతమంది పాటిస్తున్నారు?)"
    },
    {
      "row": 9,
      "number": 17,
      "text": "పో"
    },
    {
      "row": 10,
      "number": 18,
      "text": "చెయ్యి విభక్తి ప్రత్యయం"
    },
    {
      "row": 11,
      "number": 19,
      "text": "అక్షర మధ్యం ఆఖరిది"
    },
    {
      "row": 12,
      "number": 22,
      "text": "మూడు మాటలు, ముమ్మాటికి మొగుళ్ళు."
    }
  ],
  "downEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "జావళి ప్రారంభం ... నిలయమునకు రమ"
    },
    {
      "row": 2,
      "number": 2,
      "text": "ఇదో మలేరియా తెచ్చే ప్రాణి"
    },
    {
      "row": 3,
      "number": 3,
      "text": "ఆరు – కథలు చెప్పాడు రావిశాస్త్రి"
    },
    {
      "row": 4,
      "number": 4,
      "text": "సంగీత సర్వస్వం"
    },
    {
      "row": 5,
      "number": 6,
      "text": "ప్రాచీనారణ్యంలో నవీన దేశం"
    },
    {
      "row": 6,
      "number": 9,
      "text": "అరణ్యం! దేవభాషలో కాదు, తెలుగులో!"
    },
    {
      "row": 7,
      "number": 10,
      "text": "ఎవరన్నారు దేశభాషలందు తెలుగు లెస్స 16. నది"
    },
    {
      "row": 8,
      "number": 20,
      "text": "చంద్రుణ్ణి తవ్వింది పదిహేడు"
    },
    {
      "row": 9,
      "number": 21,
      "text": "నిత్య బహువచనం, పాపా!"
    }
  ]
}