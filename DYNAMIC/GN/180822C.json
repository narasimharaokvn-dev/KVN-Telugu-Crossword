{
  "sheetName": "180822",
  "identity": "180822C",
  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "గాడిద బూడిద రంగే, కాదన్నదెవరు?"
    },
    {
      "row": 2,
      "number": 3,
      "text": "సంపదలేవీ యిలా వెంటరావని హరిశ్చంద్రుడు వాపోయాడు"
    },
    {
      "row": 3,
      "number": 5,
      "text": "మల్ల వాహనుల పేర్లలోని మబ్బు"
    },
    {
      "row": 4,
      "number": 7,
      "text": "పెత్తల్లిని పిలవడానికి అంత ఆశ్చర్యపడాలా!"
    },
    {
      "row": 5,
      "number": 8,
      "text": "గింబళి కాక కంబళి అడిగినా ఆ సీత్కారమేల? 9. రెండు వైపులనుంచీ గుచ్చుకొనే ముల్లు"
    },
    {
      "row": 6,
      "number": 10,
      "text": "ప్రపంచం మొదట్లో అసలున్నదేమిటో తెలుసా!, చలివేంద్రం"
    },
    {
      "row": 7,
      "number": 11,
      "text": "ఖాతాలో డబ్బు వెయ్యమంటే అలా తడబడతావేం?"
    },
    {
      "row": 8,
      "number": 13,
      "text": "యుగకర్త జాతి దోమ తోకలో చిక్కింది 14. పది వరసల్లో కనిపించే చెండు"
    },
    {
      "row": 9,
      "number": 15,
      "text": "శ్రుతికి జత అచ్చంగా మోసం!"
    },
    {
      "row": 10,
      "number": 16,
      "text": "రెండు భాషల్లో రమ్మని పిలిచినందుకే కోర్టులో కేసు వేసేయాలా?"
    },
    {
      "row": 11,
      "number": 18,
      "text": "మన భాష సరిగా రాకపోవడం జబ్బే కదా!"
    },
    {
      "row": 12,
      "number": 19,
      "text": "ఈ ఉదంతం విన్నారా? జంతువుకి రెండున్నా, దేవునికి ఒకటే ఉంటుందట!"
    },
    {
      "row": 13,
      "number": 21,
      "text": "దండం తల్లీ!"
    },
    {
      "row": 14,
      "number": 22,
      "text": "చివర లోపించింది"
    },
    {
      "row": 15,
      "number": 25,
      "text": "ఒక ఎం.టి.ఆర్, ఒక భరణి, ఒక గౌతమ్ సిద్ధార్థ్ !"
    },
    {
      "row": 16,
      "number": 26,
      "text": "ఉత్తరభాద్రపద శివనక్షత్రమా?"
    },
    {
      "row": 17,
      "number": 30,
      "text": "ఇలాంటి వేట మనకెక్కడా కనిపించదు, ది ఎపిక్ హంట్ అనవచ్చు!"
    },
    {
      "row": 18,
      "number": 31,
      "text": "మూడోది"
    },
    {
      "row": 19,
      "number": 32,
      "text": "ఏడోది, మూడోదానితో కలిస్తే తవ్వడం మొదలుపెట్టవచ్చు"
    }
  ],
  "downEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "ఈశ్వరదత్తమైన జేజిమామయ్య అనువాదం, మంచి వాదమే!"
    },
    {
      "row": 2,
      "number": 2,
      "text": "చిరంజీవి దాచుకున్న ట్రోఫీ"
    },
    {
      "row": 3,
      "number": 3,
      "text": "ఇది లెక్కగా ఉండేది ఒక్కడికే కాబోలు!"
    },
    {
      "row": 4,
      "number": 4,
      "text": "రహస్యంగా సీతను శరణు వేడితే, అణా లేని సాకేత్ కవి మిలేంగే"
    },
    {
      "row": 5,
      "number": 6,
      "text": "పాపం. తిరగబడి పడిపోయింది!"
    },
    {
      "row": 6,
      "number": 7,
      "text": "రసాయనశాస్త్రంలో ఎల్లులు లేని భారతీ విదుషి 10. ప్రభావమున్న ప్రజ్ఞగలవాడు"
    },
    {
      "row": 7,
      "number": 12,
      "text": "నీటి అలల సంగీతం"
    },
    {
      "row": 8,
      "number": 17,
      "text": "ఐదుసార్లు ప్రతిరోజు మానకుండా చెయ్యాలి 18. విరిబోణి అనే కాదు కృష్ణవేణిని యిలా కూడా అనవచ్చు"
    },
    {
      "row": 9,
      "number": 20,
      "text": "గతాన్ని తిరగేసి రమ్మంటే ఇక్కడి మాటలక్కడ చెప్పే తగువులమారి వచ్చాడు."
    },
    {
      "row": 10,
      "number": 23,
      "text": "తోలు తీస్తే ఎంతోకొంత మిగిలేవి అచ్చులే"
    },
    {
      "row": 11,
      "number": 24,
      "text": "పార్వతీశుని సృష్టించిన నారసింహుడు"
    },
    {
      "row": 12,
      "number": 27,
      "text": "సంక్షిప్తంగా తెలుగు రక్షకుని పిలిస్తే విశ్రాంతి దొరుకుతుంది"
    },
    {
      "row": 13,
      "number": 28,
      "text": "కొంటెకి జంట"
    },
    {
      "row": 14,
      "number": 29,
      "text": "చివరి చివరన ఉంటే ఇదే గతి!"
    }
  ]
}