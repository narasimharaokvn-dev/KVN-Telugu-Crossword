  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "మాటలమడుగులో దయతో కాలు పెట్టండి, అంటున్నారీవిడ (6)"
    },
    {
      "row": 2,
      "number": 3,
      "text": "చిట్టగాంగ్ విప్లవం లోని చైతన్యం (6)"
    },
    {
      "row": 3,
      "number": 6,
      "text": "పత్తి చూస్తే ప్రతిదీ కాలేదీ (2)"
    },
    {
      "row": 4,
      "number": 8,
      "text": "అటుగా అకులన్నీ మేసినది ఆడు మేకా? పాడు మేక కదా! (2)"
    },
    {
      "row": 5,
      "number": 10,
      "text": "మరకతములో పండునది (4)"
    },
    {
      "row": 6,
      "number": 12,
      "text": "పీలగా Serr Stry కడపటిది కన్నది (4)"
    },
    {
      "row": 7,
      "number": 14,
      "text": "సగం తెరిచినదే ప్రచురించినది (4)"
    },
    {
      "row": 8,
      "number": 15,
      "text": "ముద్దుతోడిదే (4)"
    },
    {
      "row": 9,
      "number": 16,
      "text": "గాల్లో ఎగిరేదే (3)"
    },
    {
      "row": 10,
      "number": 18,
      "text": "మంచంకోళ్ళలా ముగ్గురున్నది వీరే (5)"
    },
    {
      "row": 11,
      "number": 19,
      "text": "ఏ కాలమైతేనేమి కొంగతపస్సు దొంగదే (6)"
    },
    {
      "row": 12,
      "number": 21,
      "text": "అటుదిటుగా మెరిసిన పాశం (2)"
    },
    {
      "row": 13,
      "number": 22,
      "text": "చివర ఉకారము లేనిది, ఊపిరిత్తులకిబ్బంది, రుచికాదు (3)"
    },
    {
      "row": 14,
      "number": 24,
      "text": "20 నిలువు దెబ్బకి కకావికలైన జనం (2)"
    },
    {
      "row": 15,
      "number": 26,
      "text": "ఆకులున్న కుటీరమే (4)"
    },
    {
      "row": 16,
      "number": 28,
      "text": "తెరచినా, మూసినా జంటే, రెండే (4)"
    },
    {
      "row": 17,
      "number": 30,
      "text": "అస్తవ్యస్తంగా ఉన్నా వంద ఉంటేనే లెక్క (4)"
    },
    {
      "row": 18,
      "number": 32,
      "text": "ఒరే! వగలు కాదురా బాబూ! ఎప్పుడూనూ (4)"
    },
    {
      "row": 19,
      "number": 34,
      "text": "గొప్ప మహారాజును గురించి రాసిన గొప్ప కావ్యం, ఉత్తమం (6)"
    },
    {
      "row": 20,
      "number": 35,
      "text": "ఒకటైతే నంది అవార్డు, ఎక్కువున్నాయి కనక సాహిత్య అకాడమీ అవార్డు ... బంగారంలా ఉండేవి (6)"
    }
  ],
  "downEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "తిరిపెమెత్తి పూత పూయచ్చా? (2)"
    },
    {
      "row": 2,
      "number": 2,
      "text": "తిరగేసి పూసినదా? (3)"
    },
    {
      "row": 3,
      "number": 4,
      "text": "తొలిమానపు పున్నమికి కకలిపితే ఆ మాసమే (3)"
    },
    {
      "row": 4,
      "number": 5,
      "text": "తలతీసి తిరగేస్తే ఎంత రాజైనా ఏమవుతాడు? చెలికత్తె కాక? పాపం! (2)"
    },
    {
      "row": 5,
      "number": 6,
      "text": "ఈయన రాజ్పథ్ మీద నిలబడి జాతికి సొందేషాలిచ్చేవారు (6)"
    },
    {
      "row": 6,
      "number": 7,
      "text": "సత్తాలేక ఊరేగేవాడు (6)"
    },
    {
      "row": 7,
      "number": 9,
      "text": "ఆక్షేపణకు తావులేని క్షిపణివీరుడు (6)"
    },
    {
      "row": 8,
      "number": 10,
      "text": "పుల్లావుకు ఎర్రరంగు వేస్తే బావుంది (4)"
    },
    {
      "row": 9,
      "number": 11,
      "text": "సమూలము సరిచేసి కుదిస్తే బాగా దంచుతుంది (4)"
    },
    {
      "row": 10,
      "number": 12,
      "text": "లత మీద చీముంటుంది కానీ లతే చీమవుతుందా (4)"
    },
    {
      "row": 11,
      "number": 13,
      "text": "కిందనించి ఎడ్లని అదిలించాలి (4)"
    },
    {
      "row": 12,
      "number": 16,
      "text": "విలువదిలిన బాణం రేటెక్కువ (3)"
    },
    {
      "row": 13,
      "number": 17,
      "text": "దకారము కాని చతుష్టయము (3)"
    },
    {
      "row": 14,
      "number": 18,
      "text": "మన అన్నవరం సత్తెన్న ని చూసి శబరిమల చేరిందా? (2)"
    },
    {
      "row": 15,
      "number": 20,
      "text": "పులిలా పవర్ స్టార్ విసిరినది (2)"
    },
    {
      "row": 16,
      "number": 21,
      "text": "పేరు పూర్తిగా లేకపోయినా ఈశ్వరకృపగల తొలిపౌరుడు, (6)"
    },
    {
      "row": 17,
      "number": 23,
      "text": "ఆకాశంలో పూచిందా, అందుతుందా, అసలుందా? (6)"
    },
    {
      "row": 18,
      "number": 25,
      "text": "మొదటి మహిళకి ఈ పాటి ప్రతిభ వద్దూ? (6)"
    },
    {
      "row": 19,
      "number": 26,
      "text": "ప్రదీప్ సర్కార్ లోలిత కు పెళ్ళయింది (4)"
    },
    {
      "row": 20,
      "number": 27,
      "text": "మళ్ళీ ప్రకాశించేదే (4)"
    },
    {
      "row": 21,
      "number": 28,
      "text": "భర్త, మామలతో మాజీ విశ్వసుందరి ఆటా, పాటా (4)"
    },
    {
      "row": 22,
      "number": 29,
      "text": "ఉడుములకతి దగ్గరగా, కాస్త వేరుగా వినిపించే కష్టాలు (4)"
    },
    {
      "row": 23,
      "number": 31,
      "text": "ఎటునించైనా ఇన్నే ఉపచారాలు (3)"
    },
    {
      "row": 24,
      "number": 33,
      "text": "తలలేక తిరుగాడిన కీర్తి సరిగమల్లోనా? (3)"
    }
  ]
}