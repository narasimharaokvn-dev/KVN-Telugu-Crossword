  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "సిద్ధించు చివరకు వ్యవసాయం (4)"
    },
    {
      "row": 2,
      "number": 4,
      "text": "ఇదో పద్య లక్షణం (5)"
    },
    {
      "row": 3,
      "number": 7,
      "text": "కమతము సరిగ్గా సాగాలంటే మాయ కావాలి (4)"
    },
    {
      "row": 4,
      "number": 9,
      "text": "ఆ వానలు జోరుగా పడ్డట్టు గుర్తు (4)"
    },
    {
      "row": 5,
      "number": 10,
      "text": "కవిరాసేది కత మారిస్తే కళ్ళెం (3)"
    },
    {
      "row": 6,
      "number": 11,
      "text": "తేనెలొలికించే కీటకం (5)"
    },
    {
      "row": 7,
      "number": 12,
      "text": "మబ్బుకమ్మితే నీటిమధ్య ములుచ అప్పుడప్పుడు కనిపిస్తాడు (5)"
    },
    {
      "row": 8,
      "number": 14,
      "text": "వెనుకనుండి చూసినా అదే శరీరభాగం (3)"
    },
    {
      "row": 9,
      "number": 15,
      "text": "మేఘాలుచేసే గర్జనలు (4)"
    },
    {
      "row": 10,
      "number": 17,
      "text": "రాజుగారు చల్లగా ఉండాలంటే పరిచారిక చేతిలో దుండాలి (4)"
    },
    {
      "row": 11,
      "number": 19,
      "text": "గడువుకి చెల్లించాల్సిన డబ్బూ, న్యాయాధిపతి ఇచ్చే రోజూ ఒకటే (3)"
    },
    {
      "row": 12,
      "number": 21,
      "text": "చేతి చివర కలకాలము కలసిఉండే పుట్టుమచ్చ (6)"
    },
    {
      "row": 13,
      "number": 23,
      "text": "యమపురితో వచ్చే బాధ భరించలేనిది (6)"
    },
    {
      "row": 14,
      "number": 24,
      "text": "అమావాస్య కాని పంచదశి (3)"
    },
    {
      "row": 15,
      "number": 25,
      "text": "ఉదాహరణకి అధర్వం చివర ఉపనిషత్తు? (4)"
    },
    {
      "row": 16,
      "number": 26,
      "text": "బ్రతుకు గడవాలంటే కూలికి వినయం ముందు చేర్చుకోవాలి (4)"
    },
    {
      "row": 17,
      "number": 28,
      "text": "అల్లకల్లోలంలో పడ్డ కొత్తిమిరి (3)"
    },
    {
      "row": 18,
      "number": 30,
      "text": "కాటుక లేని ఆకాశము (5)"
    },
    {
      "row": 19,
      "number": 32,
      "text": "మెడకో తాడు? కాదు ఆభరణ విశేషం (5)"
    },
    {
      "row": 20,
      "number": 34,
      "text": "నీటిమధ్యలో చివరకి కరటి చేరిందంటే చిక్కుతో కూడుకుంటుంది (3)"
    },
    {
      "row": 21,
      "number": 36,
      "text": "తలలు బోడులైనా, ఇవి బోడి కావు అని పాతకాలం నానుడి (4)"
    },
    {
      "row": 22,
      "number": 37,
      "text": "విష్ణుదేవుని భటుడు రాక్షసుడా? (4)"
    },
    {
      "row": 23,
      "number": 38,
      "text": "భద్రా! గ్రామంలో లెక్కలు రాసేవాడు వస్తే క్షవరమే (5)"
    },
    {
      "row": 24,
      "number": 39,
      "text": "నయవంచకులు గొంతుకోసేది దీనితోనే (4)"
    }
  ],
  "downEntries": [
    {
      "row": 1,
      "number": 2,
      "text": "ఈ ఇంట్లో నటనం ఒక ఆట (5)"
    },
    {
      "row": 2,
      "number": 3,
      "text": "ఉదాహరణకి అజంతా, ఎల్లోరా (3)"
