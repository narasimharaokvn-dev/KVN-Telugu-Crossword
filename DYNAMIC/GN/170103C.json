{
  "sheetName": "170103",
  "identity": "170103C",
  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "తారుమారై విరహ సలాముగా మారిన శ్రీనాధుని పుస్తకం (6)"
    },
    {
      "row": 2,
      "number": 5,
      "text": "హా! మతభారము... ఎంత చెడ్డా, మన పవిత్ర గ్రంధమే (6)"
    },
    {
      "row": 3,
      "number": 9,
      "text": "గుర్తు తప్పుకి ముందుండేది (2)"
    },
    {
      "row": 4,
      "number": 10,
      "text": "మనం బిగించుకుని కూర్చుంటే విష్ణు పూజ ఎవరు చేస్తారు? (2)"
    },
    {
      "row": 5,
      "number": 13,
      "text": "అక్కడక్కడ వేలుమధ్యన చిక్కుకున్న శతకకారుడు (3)"
    },
    {
      "row": 6,
      "number": 14,
      "text": "గుండెలోకి పాతుకున్న గుండు ఇటునుండే ఇక్కడినుంచే వచ్చింది (3)"
    },
    {
      "row": 7,
      "number": 16,
      "text": "నీడకు ముందుంటుంది. ఒట్టు. (2)"
    },
    {
      "row": 8,
      "number": 17,
      "text": "అరటిచెట్టులాంటి అప్సరస (2)"
    },
    {
      "row": 9,
      "number": 20,
      "text": "ప్రకృతిని ఎదుర్కొన్న గృహము (2)"
    },
    {
      "row": 10,
      "number": 21,
      "text": "అమ్మలక్కల పరిశ్రమతో పిడత (2)"
    },
    {
      "row": 11,
      "number": 22,
      "text": "ఈ పరిమళం వద్దని వారిస్తూ కళ్ళు మూసుకోకు. తిరిగి చూడు (3)"
    },
    {
      "row": 12,
      "number": 23,
      "text": "స్వర్గానికీ దీనికీ ఎగరలేనమ్మ (2)"
    },
    {
      "row": 13,
      "number": 24,
      "text": "కలువల్లో అక్కడక్కడ కనపడే జత (2)"
    },
    {
      "row": 14,
      "number": 25,
      "text": "గ్రహాలు అనుకూలిస్తే పట్టేది కాబోలు (5)"
    },
    {
      "row": 15,
      "number": 26,
      "text": "ముక్కున్నంతసేపూ ఇది ఉంటుందిట, సామెత ప్రకారం (3)"
    },
    {
      "row": 16,
      "number": 27,
      "text": "వడ్డీని సంపాదించే మూలధనం బురదా? (3)"
    },
    {
      "row": 17,
      "number": 30,
      "text": "పస మధ్యన ఉంటే పండవుతుంది (3)"
    },
    {
      "row": 18,
      "number": 31,
      "text": "విన్నపాలు లో సగం భాగం (2)"
    },
    {
      "row": 19,
      "number": 36,
      "text": "కారు, తాడు, సుర ఇవన్నీ ఒక క్రమంలో పేరిస్తే రాక్షసుడౌతాడు (6)"
    },
    {
      "row": 20,
      "number": 38,
      "text": "రామ! రామ! రామ! రామ! రామ!... అవి తోటల్లా కనిపిస్తాయికానీ దేవాలయాలు (6)"
    },
    {
      "row": 21,
      "number": 40,
      "text": "అసలే చిరాకు. మధ్యలో గురక మొదలుపెడితే పుట్టే దళం (4)"
    },
    {
      "row": 22,
      "number": 41,
      "text": "జింక మధ్యలొ వాగడం ఆరంభిస్తే పళ్ళెం (4)"
    },
    {
      "row": 23,
      "number": 42,
      "text": "తునాతునకలు అయినా కనపడే ప్రతిరూపం (3)"
    }
  ],
  "downEntries": [
    {
      "row": 1,
      "number": 2,
      "text": "అణుపు లాంటి సన్నని నూక (2)"
    },
    {
      "row": 2,
      "number": 3,
      "text": "డబ్బుతోవ్యవహారం! కావాలా దేవి? తలకొట్టి బెడిసికొట్టింది (4)"
    },
    {
      "row": 3,
      "number": 4,
      "text": "ఎట్నుంచి చూసినా సంతోషము (3)"
    },
    {
      "row": 4,
      "number": 6,
      "text": "చంద్రభానుచరిత్రలో తలకిందులైన మాసం (2)"
    },
    {
      "row": 5,
      "number": 7,
      "text": "లేతదనం తరంగిణిలా కనిపిస్తుంది అటుపిమ్మట (5)"
    },
    {
      "row": 6,
      "number": 8,
      "text": "మగటిమి పస అక్కడక్కడ తిరిగి పుంజుకుంటే నేర్పు అదే వస్తుంది (3)"
    },
    {
      "row": 7,
      "number": 9,
      "text": "గతికి ముందు వచ్చే ఎక్కువ మాట (2)"
    },
    {
      "row": 8,
      "number": 11,
      "text": "మనమున మగడితో తిరుగు ప్రయాణం (4)"
    },
    {
      "row": 9,
      "number": 12,
      "text": "పూలరంగడు సరిగ్గా చూస్తే అసాధ్యుడే (4)"
    },
    {
      "row": 10,
      "number": 15,
      "text": "కష్టం పొరకప్పిన తప్పు (2)"
    },
    {
      "row": 11,
      "number": 18,
      "text": "సంతోషాలతోట ఆడవారికేనా? మాలతీచందూర్ ను అడిగితే సరి. (5)"
    },
    {
      "row": 12,
      "number": 19,
      "text": "పట్టుకో గలనా బామ్మ ఈ పాతచిత్రాన్ని (5)"
    },
    {
      "row": 13,
      "number": 22,
      "text": "ఇది చేస్తే అదుపులో ఉంటారు (3)"
    },
    {
      "row": 14,
      "number": 23,
      "text": "ఇది చెప్పేరంటే పన్లోంచి తీసేసేరన్నమాటే! (4)"
    },
    {
      "row": 15,
      "number": 28,
      "text": "అడవికుక్క మధ్యలేకుంటే చర్మం (2)"
    },
    {
      "row": 16,
      "number": 29,
      "text": "దేశవాళీ పద్ధతిలో తయారుచేసిన సరకు (4)"
    },
    {
      "row": 17,
      "number": 32,
      "text": "అహోబలపండితీయంలో రాసేది (3)"
    },
    {
      "row": 18,
      "number": 33,
      "text": "తీవ్రమైన కదలికలు మధ్య కంప భూములు (5)"
    },
    {
      "row": 19,
      "number": 34,
      "text": "ఎంతకోసుకున్నా తరగని దూరం (2)"
    },
    {
      "row": 20,
      "number": 35,
      "text": "జంజాటములో సరిగా దాగున్న కాలం (2)"
    },
    {
      "row": 21,
      "number": 36,
      "text": "పనంతా శుభ్రంగా చేస్తే వెలుతురు కనిపిస్తుంది (3)"
    },
    {
      "row": 22,
      "number": 37,
      "text": "ఉండడానికి ఠికాణా, చిల్లుగవ్వలేకుండానే చిరకాల నివాసస్థలం (3)"
    },
    {
      "row": 23,
      "number": 39,
      "text": "చారికి దొరికిన నీచమైన కొలువు (3)"
    }
  ]
}