{
  "sheetName": "190531",
  "identity": "190531C",
  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "సువాసన తొలుత లక్కతో తయారు చేశారు (5)"
    },
    {
      "row": 2,
      "number": 4,
      "text": "ఉదాహరణకి సర్వ వశంకరి (3)"
    },
    {
      "row": 3,
      "number": 6,
      "text": "రామా! నాజీ పరిపాలనా? ఆ ఉద్యోగం నాకొద్దు (4)"
    },
    {
      "row": 4,
      "number": 8,
      "text": "నీళ్ళు జనాలకి మేలు చేస్తాయి (4)"
    },
    {
      "row": 5,
      "number": 9,
      "text": "ఎంతలా రికామీగా తిరిగినా రాత్రుళ్ళు దొంగతనాలు జరగకుండా చూడ్డమే ఇతనిపని (3)"
    },
    {
      "row": 6,
      "number": 10,
      "text": "బాధతో పాడినపాటకి తందానతాన (2)"
    },
    {
      "row": 7,
      "number": 11,
      "text": "33 నిలువులో కొంత వెనుకబడ్డ అబద్దం (2)"
    },
    {
      "row": 8,
      "number": 13,
      "text": "కంటకంతో ఎప్పుడూ ఓడేది? (4)"
    },
    {
      "row": 9,
      "number": 15,
      "text": "అక్కడ అంతంతో చూడుము తిరిగి మొదలు కనిపిస్తుంది (4)"
    },
    {
      "row": 10,
      "number": 17,
      "text": "మందు పుటక ఒకదారికి వస్తే అసూయ కలుగుతుంది (5)"
    },
    {
      "row": 11,
      "number": 20,
      "text": "నూరడుగుల క్రిమితో దంపుడుసాధనం (5)"
    },
    {
      "row": 12,
      "number": 22,
      "text": "వీణా నది (4)"
    },
    {
      "row": 13,
      "number": 23,
      "text": "వశిష్ఠుని భార్య మరులుతీగ (3)"
    },
    {
      "row": 14,
      "number": 25,
      "text": "సహవసతిలో దాగున్న రెండో పెళ్ళాం కాబోలు (3)"
    },
    {
      "row": 15,
      "number": 26,
      "text": "మనకి అనుకూలంగా ఉండేలా రాసుకునే పత్రం లాగ కనిపిస్తుంది కానీ ఇది మరణశాసనం (4)"
    },
    {
      "row": 16,
      "number": 28,
      "text": "ఆడమేకలనే కాసేవాడా? కాదు (5)"
    },
    {
      "row": 17,
      "number": 31,
      "text": "కులాలు కుడి ఎడమైతే విలాసవతి పుడుతుంది (5)"
    },
    {
      "row": 18,
      "number": 32,
      "text": "తిరిగిన వాడి జన్మలో ముసురు (4)"
    },
    {
      "row": 19,
      "number": 34,
      "text": "దుర్యోధనుడి భార్య ప్రతిమను భారతంలో చూస్తాం. (4)"
    },
    {
      "row": 20,
      "number": 37,
      "text": "ప్రాయంలో ఉన్న వాడు పుట్టిన సంవత్సరం (2)"
    },
    {
      "row": 21,
      "number": 39,
      "text": "అడ్డం ఆరులోసగం సంధి (2)"
    },
    {
      "row": 22,
      "number": 40,
      "text": "వరిమడి వరుస (3)"
    },
    {
      "row": 23,
      "number": 41,
      "text": "సింగినాదంతోపాటు వచ్చే వంటదినుసు ఈసడింపా? ఏమీలేదు (4)"
    },
    {
      "row": 24,
      "number": 43,
      "text": "పాలంపని కోసం వ్యయం వసారా పూర్తికాకుండా చూడాలి (4)"
    },
    {
      "row": 25,
      "number": 44,
      "text": "ఈ జీతానికి కూర్చుని పనిచెయ్యకూడదు (3)"
    },
    {
      "row": 26,
      "number": 45,
      "text": "పెళ్ళికొడుకు నడుముకు కట్టేది కాదు, 1961లో భారత ప్రభుత్వం నిషేధించినది (5)"
    }
  ],
  "downEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "వర్షంకోసం చేసే పూజ గంత జాగర కాదు (5)"
    },
    {
      "row": 2,
      "number": 2,
      "text": "ఏనుగు దీర్ఘం తీస్తే గాలి కనబడుతుంది! (3)"
    },
    {
      "row": 3,
      "number": 3,
      "text": "ఇదంటే తన పాముని పడతొయ్యడమే (5)"
    },
    {
      "row": 4,
      "number": 4,
      "text": "స్వామిని తమిళనాట ప్రవహించే నదికి కాదే మార్పు? (3)"
    },
    {
      "row": 5,
      "number": 5,
      "text": "శిరసు వంకరగా ఉంటే అవమానం (4)"
    },
    {
      "row": 6,
      "number": 6,
      "text": "సారంగధరాభ్యుదయములో ఎదురుతిరిగిన కృష్ణసఖి (2)"
    },
    {
      "row": 7,
      "number": 7,
      "text": "అక్షరంపోయి తిరిగి కలిసినా పసికట్టేది (3)"
    },
    {
      "row": 8,
      "number": 12,
      "text": "కసాయివాడు సాయిలేనప్పుడు చేసే వ్యవహారము (3)"
    },
    {
      "row": 9,
      "number": 14,
      "text": "ఉదాహరణకి అమ్మా, నాన్నా, కొడుకూ, కూతురూ (3)"
    },
    {
      "row": 10,
      "number": 16,
      "text": "నెమలి చల్లిన పేడనీళ్ళు (3)"
    },
    {
      "row": 11,
      "number": 18,
      "text": "మాయల మరాఠీకి మాత్రమే విధిగా తెలియాల్సినవి. (5)"
    },
    {
      "row": 12,
      "number": 19,
      "text": "సుగ్రీవుడి అన్నకి మధ్యలో ఇంటికి ముందుండేది (3)"
    },
    {
      "row": 13,
      "number": 21,
      "text": "చేతిగుడ్డలు (5)"
    },
    {
      "row": 14,
      "number": 24,
      "text": "మేలుకొలుపు చెప్పే వర్ణం (3)"
    },
    {
      "row": 15,
      "number": 27,
      "text": "కోతి జీడిలతో మొదలయ్యే చెట్టు (3)"
    },
    {
      "row": 16,
      "number": 29,
      "text": "ఈ లెక్కలు మనవే (3)"
    },
    {
      "row": 17,
      "number": 30,
      "text": "ఏదుపంది ఎముక (3)"
    },
    {
      "row": 18,
      "number": 33,
      "text": "నీలోత్పలము వల్ల నకలు తారుమారైంది (5)"
    },
    {
      "row": 19,
      "number": 35,
      "text": "రాశిలో ధుమధుమలాడడం మొదలెడితే భిక్షాన్నం దొరుకుతుంది (5)"
    },
    {
      "row": 20,
      "number": 36,
      "text": "లక్ష్మణుని కాపాడడం కోసం జీవనిధుల్ని ఒట్టి హనుమంతుడు తెచ్చిన ఔషధం (4)"
    },
    {
      "row": 21,
      "number": 38,
      "text": "ఎటునుండైనా కట్టుకునే చీర (3)"
    },
    {
      "row": 22,
      "number": 40,
      "text": "రాజు మధ్యలో “హు\" అంటే తొమ్మిదిలో ఒకటి (3)"
    },
    {
      "row": 23,
      "number": 41,
      "text": "కవి జీతం బ్రతుకు తెరువుకు పనికొస్తుంది (3)"
    },
    {
      "row": 24,
      "number": 42,
      "text": "ఇష్టమే కానీ ఎక్కువ ఖరీదు (2)"
    }
  ]
