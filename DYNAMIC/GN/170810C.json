    {
      "row": 16,
      "number": 23,
      "text": "శ్రీవారి పొడుగుబొట్టు"
    },
    {
      "row": 17,
      "number": 24,
      "text": "రకము సరి చెయ్యి"
    },
    {
      "row": 18,
      "number": 27,
      "text": "ఒడిశా సరిహద్దులో ఉరికే జలపాతం."
    },
    {
      "row": 19,
      "number": 28,
      "text": "తీర్ధంకరుడి వెంట నగ్నప్రాదాల నడువు 30. లక్షాధికారిని కూడా ఇదే మింగమన్నాడు శేషప్పకవి"
    },
    {
      "row": 20,
      "number": 31,
      "text": "పడతి పలుకు"
    },
    {
      "row": 21,
      "number": 33,
      "text": "దుర్గంధం"
    },
    {
      "row": 22,
      "number": 34,
      "text": "లక్ష సిరాచుక్కల మధ్య దాక్కున్న దానివి"
    },
    {
      "row": 23,
      "number": 36,
      "text": "పాటతో పల్లవించే గులాబి వర్గం"
    },
    {
      "row": 24,
      "number": 37,
      "text": "ఆరున్నొక్కరాగం తీయు"
    },
    {
      "row": 25,
