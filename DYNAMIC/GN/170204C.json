{
  "sheetName": "170204",
  "identity": "170204C",
  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "ముందుభాగాన చెదిరిన వరసా? (3)"
    },
    {
      "row": 2,
      "number": 3,
      "text": "కుడియెడమైన ప్రయత్నం (3)"
    },
    {
      "row": 3,
      "number": 5,
      "text": "ఒక నది తిరగబడితేనే సమభావం (3)"
    },
    {
      "row": 4,
      "number": 7,
      "text": "దానమును కాక కాస్త సద్దుకుని దీనిని స్వీకరించడం ఉచితమే (3)"
    },
    {
      "row": 5,
      "number": 9,
      "text": "ఏది ధర్మం, పదధర్మం? తేల్చుకోలేని విషమస్థితి (5)"
    },
    {
      "row": 6,
      "number": 10,
      "text": "ఊరికి ఉపకారం (5)"
    },
    {
      "row": 7,
      "number": 11,
      "text": "మట్టిపలక ఫ్రేము దీనితో చేస్తారు (3)"
    },
    {
      "row": 8,
      "number": 12,
      "text": "కావ్యం ముక్కస్య ముల్కానువాదం గట్టిదైన చెర (3)"
    },
    {
      "row": 9,
      "number": 13,
      "text": "వసంతంలో మనవాలల్లె సరిగా పడితే మనోహరం (5)"
    },
    {
      "row": 10,
      "number": 15,
      "text": "బేసరి కోసం పోయేది కాలిపోయి రూపుమారిన పులి ముక్కు కడకా? (5)"
    },
    {
      "row": 11,
      "number": 17,
      "text": "కక్షిదారు డాక్యుమెంటు తిప్పలుపడి అదనంగా సాగిన మానవతులకా? (6)"
    },
    {
      "row": 12,
      "number": 19,
      "text": "అందులో సాగిన అంచు మధ్యలో మోది అంగీకరించు (4)"
    },
    {
      "row": 13,
      "number": 21,
      "text": "వేదమంత్రాన్ని వత్తిపలికితే విశ్వాసం కలుగుతుంది. (3)"
    },
    {
      "row": 14,
      "number": 23,
      "text": "18 నిలువును తలదన్నే గర్వం (3)"
    },
    {
      "row": 15,
      "number": 24,
      "text": "అటునుంచి గురితప్పనివాడు (4)"
    },
    {
      "row": 16,
      "number": 25,
      "text": "దిక్పాలకులెందరు? (6)"
    },
    {
      "row": 17,
      "number": 28,
      "text": "వాటికాపతి సవరించిన పావన కలి (5)"
    },
    {
      "row": 18,
      "number": 31,
      "text": "ముద్దగా ముడుచుకున్నా, రెక్కలు విప్పుకున్నా ఎర్రగా వెలిగే పువ్వులు (5)"
    },
    {
      "row": 19,
      "number": 32,
      "text": "కోపానికిది నకలు కాదు (3)"
    },
    {
      "row": 20,
      "number": 33,
      "text": "ఇటునుంచి కాబట్టి అటునుంచి కూడా (3)"
    },
    {
      "row": 21,
      "number": 34,
      "text": "అస్తవ్యస్తంగా ఆవాలు మింగేసిన ఆనార జీవాలు మందంగా వినిపించే అందెల సవ్వడి (5)"
    },
    {
      "row": 22,
      "number": 36,
      "text": "లోలలేని సంధిలో విలవిలా కొట్టుకోవడం తలరాత (5)"
    },
    {
      "row": 23,
      "number": 38,
      "text": "తన రథమున లిబ్బికోసం తలలు బయలు వెడలి (3)"
    },
    {
      "row": 24,
      "number": 39,
      "text": "సన్నగా ఉన్నంత మాత్రాన చవట కాదు (3)"
    },
    {
      "row": 25,
      "number": 40,
      "text": "నామ్ వాస్తే మెత్తనివనిపించినా నిజానికి గట్టివే (3)"
    },
    {
      "row": 26,
      "number": 41,
      "text": "దేవతలకు సులభంగా అర్ధమయ్యే గాడిద (3)"
    }
  ],
  "downEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "నరకాసురవధలో ప్రచ్ఛన్నంగా పాల్గొన్న అతని తల్లి (3)"
    },
    {
      "row": 2,
      "number": 2,
      "text": "తోబుట్టువుల బంధం (5)"
    },
    {
      "row": 3,
      "number": 3,
      "text": "ఆటంకపరిచే దొంగవేషం (3)"
    },
    {
      "row": 4,
      "number": 4,
      "text": "పూసల రాలతో సర్దిన పుష్పహారాలతో (6)"
    },
    {
      "row": 5,
      "number": 5,
      "text": "స్వాభావిక నవల ఓల్గా రచన (3)"
    },
    {
      "row": 6,
      "number": 6,
      "text": "లకారం నకారమై కుదురుకున్న నవముల పోత మునీశ్వరులకు నెలవు (5)"
    },
    {
      "row": 7,
      "number": 7,
      "text": "దీనితో వచ్చేది అకలేదుపు కాక మరేమిటి? (5)"
    },
    {
      "row": 8,
      "number": 8,
      "text": "ఆంధ్ర ప్రదేశ్ రాష్ట్ర సరిహద్దులు సోకని జిల్లా పూర్వనామం (3)"
    },
    {
      "row": 9,
      "number": 12,
      "text": "ప్రథమ భవ్య వర్షము (3)"
    },
    {
      "row": 10,
      "number": 13,
      "text": "పెద్దపాము మెలితిరిగే మడుగు హానా? (5)"
    },
    {
      "row": 11,
      "number": 14,
      "text": "అందలేక మోగు అందనము సరియగునేని హసన్ముఖము (4)"
    },
    {
      "row": 12,
      "number": 16,
      "text": "గట్టిగా మోగనిది విలువైనది (3)"
    },
    {
      "row": 13,
      "number": 18,
      "text": "23 అర్ధంతో వచ్చిన గొడవ (3)"
    },
    {
      "row": 14,
      "number": 20,
      "text": "బొట్టనవేలికి దగ్గరి చుట్టం (5)"
    },
    {
      "row": 15,
      "number": 21,
      "text": "విదర్భ రాకుమార్తె మాత్రమే గుర్తుపట్టగలిగిన నిషధరాజు (3)"
    },
    {
      "row": 16,
      "number": 22,
      "text": "పరిపరి నామం ఒకపరి ఇలా మారడం సహజమే? (4)"
    },
    {
      "row": 17,
      "number": 23,
      "text": "బలము, సత్తువ, వడిలో మొదటి అడుగులు కూర్చిన తాత్వికుడు (3)"
    },
    {
      "row": 18,
      "number": 26,
      "text": "పలుమారులు పలువిధాలుగ పనికొచ్చే గుడ్డముక్క (3)"
    },
    {
      "row": 19,
      "number": 27,
      "text": "మన దండ రణభూమిలో నేలను లాగే సర్దుబాటుతో ఉసురుతీయడం (6)"
    },
    {
      "row": 20,
      "number": 29,
      "text": "వైకుంఠంలో ఎల్లెడల కపాలి ఆటుపోటులతో ఉన్నది. (5)"
    },
    {
      "row": 21,
      "number": 30,
      "text": "కథలు చిగురించే కొమ్మగా మారగల మంథా కరిజ (5)"
    },
    {
      "row": 22,
      "number": 32,
      "text": "గాలి కవి దిగ్గున ఇలా అందరిలో కలిసిపోవడం పెద్ద మార్పే (5)"
    },
    {
      "row": 23,
      "number": 33,
      "text": "కత వినడానికి ఉత్సాహపడేవాళ్ళు కూడా ఇది వినడానికి వెనుకాడుతారు (3)"
    },
    {
      "row": 24,
      "number": 35,
      "text": "నూలు వడికేది (3)"
    },
    {
      "row": 25,
      "number": 36,
      "text": "మొదటే చిన్నబోయిన వీరులు సుకుమారులు (3)"
    },
    {
      "row": 26,
      "number": 37,
      "text": "రభసకు నిలువెల్లా సున్నాలు కొట్టి అక్రమంగా జరుపుకునే సంబరం (3)"
    }
  ]
}