  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "బాకీ సరసర తీర్చెయ్యాలంటే అర్థంకాని భాష నేర్చుకో (6)"
    },
    {
      "row": 2,
      "number": 4,
      "text": "అక్షరం ఉన్నా లేకున్నా తేనె తేనే (4)"
    },
    {
      "row": 3,
      "number": 7,
      "text": "జాతీయగీతంలో బ్రహ్మ (3)"
    },
    {
      "row": 4,
      "number": 10,
      "text": "కుర్చీకీ మంచానికీ ముందుండే భక్ష్య విశేషం (3)"
    },
    {
      "row": 5,
      "number": 11,
      "text": "వేలిముద్ర సంతకం? (5)"
    },
    {
      "row": 6,
      "number": 12,
      "text": "చక్కని పొందిక ఉండాలంటే మామ సగము చిక్కాలి (5)"
    },
    {
      "row": 7,
      "number": 13,
      "text": "పేరు వినడానికి ఆహ్లాదంగా అనిపించినా కడుపులోకి వెళ్ళిందంటే కల్లోలమే! (4)"
    },
    {
      "row": 8,
      "number": 14,
      "text": "గాయకుడిలా ఉన్న వంచకుడు (4)"
    },
    {
      "row": 9,
      "number": 16,
      "text": "మేఘాల్లో కొద్దిసేపు మాత్రమే వెలిగే దీపం? (3)"
    },
    {
      "row": 10,
      "number": 19,
      "text": "సమయములో మార్పులు కాగా బడిశ దొరుకుతుంది (3)"
    },
    {
      "row": 11,
      "number": 21,
      "text": "తర్జని కొసలతో గర్భం (2)"
    },
    {
      "row": 12,
      "number": 22,
      "text": "అసలే చిరాకు. మధ్యలో గురక మొదలుపెడితే పుట్టే దళం (4)"
    },
    {
      "row": 13,
      "number": 26,
      "text": "తక్కువగా మాట్లాడేవాడి వాతమిది కాబోలు (4)"
    },
    {
      "row": 14,
      "number": 28,
      "text": "కైలాస పర్వతాన దొరికే లోహం? (2)"
    },
    {
      "row": 15,
      "number": 29,
      "text": "తెలంగాణా మట్టి (3)"
    },
    {
      "row": 16,
      "number": 31,
      "text": "మంచి మనస్సు ఉన్న ధనికుడు (3)"
    },
    {
      "row": 17,
      "number": 32,
      "text": "అర్థంపర్థంలేని కథలకి ఇవి ఉండవు (4)"
    },
    {
      "row": 18,
      "number": 33,
      "text": "ముందు చదువు శ్రేష్ఠము - జబ్బుని నయంచేసే శాస్త్రం (4)"
    },
    {
      "row": 19,
      "number": 37,
      "text": "గరుడపక్షి పాముభోజనం కాదు (5)"
    },
    {
      "row": 20,
      "number": 38,
      "text": "వంశ పారంపర్యంగా వచ్చే బాధ్యత కలవాడు (5)"
    },
    {
      "row": 21,
      "number": 39,
      "text": "గణితశాస్త్రంలో తీసివేతకు విరుద్ధం (3)"
    },
    {
      "row": 22,
      "number": 40,
      "text": "పండితులు రైతులకు దున్నుకునేందుకు ఇచ్చే హక్కు (3)"
    },
    {
      "row": 23,
      "number": 41,
      "text": "ఇలాఅంటే ఏమయినా సరే అనంగీకారమే (4)"
    },
    {
      "row": 24,
      "number": 42,
      "text": "శ్రవణేంద్రియంలో దూరే జలగ (6)"
    }
  ],
  "downEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "అగ్నికణాలు వెదజల్లే ప్రాణి (4)"
    },
    {
      "row": 2,
      "number": 2,
      "text": "సారము చెడినప్పుడు తలదూరిస్తే పాతాళలోకం కనిపిస్తుంది (5)"
    },
    {
      "row": 3,
      "number": 3,
      "text": "ఓర్పులో అన్నచివరి ప్రయత్నం (5)"
