{
  "sheetName": "180620",
  "identity": "180620C",
  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "భక్తులకి సంతానాన్ని ప్రసాదించే దేవత కోసం ఆరుద్ర పదాలు (4)"
    },
    {
      "row": 2,
      "number": 3,
      "text": "ఒకటి అడ్డంలో కవిగారు \"అచ్చోట తిరగేసి కొడితే దాని ఖర్మం\" అని దీనిగురించే అన్నారు (3)"
    },
    {
      "row": 3,
      "number": 5,
      "text": "ప్రభావము కల కస్తూరి? కాదు, గురుత్వాకర్షణ కేంద్రం (5)"
    },
    {
      "row": 4,
      "number": 10,
      "text": "ఈ మందు పిట్టకి పోస్తారు, సామెత ప్రకారం (2)"
    },
    {
      "row": 5,
      "number": 11,
      "text": "రాజకీయ కీటకాల మధ్య విభేదాల ధ్వని కాబోలు - ఎటునుంచైనా వినిపిస్తుంది (5)"
    },
    {
      "row": 6,
      "number": 12,
      "text": "కొండవాగు రమ్మంది. జంతువుల వేటకి వల దొరికింది (3)"
    },
    {
      "row": 7,
      "number": 14,
      "text": "ఊడ్చిపెట్టుకు పోయేదానికి వంద ముఖాలా? (5)"
    },
    {
      "row": 8,
      "number": 15,
      "text": "మా తాతలు పిల్లల్ని మొదట్లో మధ్యలో కూర్చోపెట్టుకున్న కన్నవారు (5)"
    },
    {
      "row": 9,
      "number": 17,
      "text": "అధికారికంగా సమ్మతిస్తే వేసేది (2)"
    },
    {
      "row": 10,
      "number": 19,
      "text": "చీమలు పెట్టే వాటి మధ్య వాననుండి కాపాడేది. చేరిస్తే చిత్తకార్తెలో మొలకలేస్తాయి (6)"
    },
    {
      "row": 11,
      "number": 22,
      "text": "హృదయం లేని గృహద్వారంతో రామాయణపాత్ర (2)"
    },
    {
      "row": 12,
      "number": 23,
      "text": "మెత్తని పకోడీలు కావాలంటే శ్రీహరి నిఘంటువు చూడాలి (5)"
    },
    {
      "row": 13,
      "number": 26,
      "text": "తుమ్మెద తేనెతిండి (5)"
    },
    {
      "row": 14,
      "number": 27,
      "text": "శాంతిపర్వంలో వెనకబడ్డ భర్త (2)"
    },
    {
      "row": 15,
      "number": 28,
      "text": "వ్యాధిని తెచ్చే కీటకాలు సమాజంలో కూడా ఉంటాయి (6)"
    },
    {
      "row": 16,
      "number": 30,
      "text": "మూతిలేని వానర సమూహము కట్టిన చీర (2)"
    },
    {
      "row": 17,
      "number": 32,
      "text": "మత్తుకలిగించే విత్తులు (5)"
    },
    {
      "row": 18,
      "number": 33,
      "text": "ఏనుగు వికృత రూపం మధ్య వగరు భరించలేనిదైతే సాంబ్రాణికడ్డీ వెలిగించండి (5)"
    },
    {
      "row": 19,
      "number": 36,
      "text": "నలభైఐదులో మొదటి సగం - పదహారులో చివర మూడొంతులు (3)"
    },
    {
      "row": 20,
      "number": 37,
      "text": "ఒకప్పటి మన ఏలికలు (5)"
    },
    {
      "row": 21,
      "number": 40,
      "text": "మృత్యువు వికృతరూపం దాలిస్తే? (2)"
    },
    {
      "row": 22,
      "number": 43,
      "text": "లవణజలము చమురుతో కలిస్తే మేఘం వస్తుందా? (5)"
    },
    {
      "row": 23,
      "number": 44,
      "text": "వేలు కొలమానం (3)"
    },
    {
      "row": 24,
      "number": 45,
      "text": "దట్టంగా కుట్టిన బట్టతో ఎగిరే పక్షి (4)"
    }
  ],
  "downEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "పనివాడికి దొరికే పన్ను? (2)"
    },
    {
      "row": 2,
      "number": 2,
      "text": "ముహూర్తంతో మదపుటేనుగు? (2)"
    },
    {
      "row": 3,
      "number": 4,
      "text": "రాయలసీమ పప్పులు ఒకప్పటి మన చిల్లర డబ్బులు (3)"
    },
    {
      "row": 4,
      "number": 5,
      "text": "ఇవే (3)"
    },
    {
      "row": 5,
      "number": 6,
      "text": "చైత్రమాసం ఏడురోజులు మద్యపాన కార్యక్రమం చెయ్యొచ్చా? (5)"
    },
    {
      "row": 6,
      "number": 7,
      "text": "మానలేని దురభిమానము లో పుట్టిన వజ్రాయుధం (4)"
    },
    {
      "row": 7,
      "number": 8,
      "text": "ఇది పక్షి కాదు. తినే చేప (4)"
    },
    {
      "row": 8,
      "number": 9,
      "text": "బలపం కట్టుకుని తిరిగే శరీరభాగం (2)"
    },
    {
      "row": 9,
      "number": 13,
      "text": "మావిచిగురు అంచులతో పర్యాయం (2)"
    },
    {
      "row": 10,
      "number": 15,
      "text": "అమ్మమ్మ లేదు పోయింది. మిగిలింది మాతులుడు మాత్రమే (2)"
    },
    {
      "row": 11,
      "number": 16,
      "text": "ఆడచీమని చంపి పీలికలు చెయ్యండి (4)"
    },
    {
      "row": 12,
      "number": 18,
      "text": "ఆకలేస్తే కడుపులో పరిగెత్తే జంతువులు (4)"
    },
    {
      "row": 13,
      "number": 19,
      "text": "మన శరీరం పైన ఉండేవాటి వల్ల వచ్చే కళంకం (4)"
    },
    {
      "row": 14,
      "number": 20,
      "text": "గండ్ర తర్వాత పట్టుకునే చేతిపనిముట్టు (3)"
    },
    {
      "row": 15,
      "number": 21,
      "text": "కారలేని హెచ్చువేత స్వభావం (3)"
    },
    {
      "row": 16,
      "number": 23,
      "text": "మంచానికి ఇది బిగించకపోతే పట్టెక్కడ? (3)"
    },
    {
      "row": 17,
      "number": 24,
      "text": "అడవిలో ఉండే పల్లె (3)"
    },
    {
      "row": 18,
      "number": 25,
      "text": "మూడు దారుల్లో తిరిగే గంగ (4)"
    },
    {
      "row": 19,
      "number": 29,
      "text": "ఆ వానలు ఆజ్ఞ లేకుండా పడితే పదునే! (2)"
    },
    {
      "row": 20,
      "number": 31,
      "text": "స్వప్నలేఖిని కాకిగోల (5)"
    },
    {
      "row": 21,
      "number": 33,
      "text": "ఈ ఉంగరపువేలుకి పేరులేదు (4)"
    },
    {
      "row": 22,
      "number": 34,
      "text": "సుగ్రీవుని భార్య మరుజన్మలో తిరిగి పుట్టింది (2)"
    },
    {
      "row": 23,
      "number": 35,
      "text": "యముడు జముడైతే అపజయ మన్నది అతీగతీ లేకుండా పోయింది (4)"
    },
    {
      "row": 24,
      "number": 37,
      "text": "తెల్లసవరములో వరస తెగింది. ఇది స్పష్టము (3)"
    },
    {
      "row": 25,
      "number": 38,
      "text": "దొందు జోడు (2)"
    },
    {
      "row": 26,
      "number": 39,
      "text": "ఎద్దు మెడలో గంట కట్టాలంటే చేష్టలుడుగుతారా? (3)"
    },
    {
      "row": 27,
      "number": 41,
      "text": "ధ్వని చేసే బరువు (2)"
    },
    {
      "row": 28,
      "number": 42,
      "text": "నండూరి నాయుడు బావ మరదలు (2)"
    }
  ]
}