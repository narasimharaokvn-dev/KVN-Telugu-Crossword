  "crossEntries": [
    {
      "row": 1,
      "number": 8,
      "text": "కృష్ణజన్మస్థానం ఆరంభంలో తెగి చక్కెర అయింది (3)"
    },
    {
      "row": 2,
      "number": 9,
      "text": "సంగీతం, సాహిత్యం, నృత్యం లాంటి ప్రక్రియల్ని ముందుండి నడిపించే పరాశక్తి (3)"
    },
    {
      "row": 3,
      "number": 10,
      "text": "ఇదో అధోలోకం (3)"
    },
    {
      "row": 4,
      "number": 11,
      "text": "ఇది మన మొహాన కనబడితే ఇబ్బందిగా ఉంటుంది (3)"
    },
    {
      "row": 5,
      "number": 12,
      "text": "శత్రువుని ఓడించే భగవంతుడి సేన లెక్కింపలేనిది (5)"
    },
    {
      "row": 6,
      "number": 14,
      "text": "సన్యాసి రాసే పద్యానికి ఉండాల్సింది (2)"
    },
    {
      "row": 7,
      "number": 15,
      "text": "అక్కడక్కడ ఒకదానితో ఒకదానికి సంబంధము లేదు (6)"
    },
    {
      "row": 8,
      "number": 17,
      "text": "తప్పెట అంగరక్షణకి ధరించేదా? (4)"
    },
    {
      "row": 9,
      "number": 19,
      "text": "క్షమించమని భగవంతుడిని అడుగుతూ వేసుకునేవి (3)"
    },
    {
      "row": 10,
      "number": 20,
      "text": "ఈ రెండింటితో వెనుకటి వగను కనిపించేలా చెయ్యొచ్చు (4)"
    },
    {
      "row": 11,
      "number": 24,
      "text": "పండుగ సంతోషం (4)"
    },
    {
      "row": 12,
      "number": 26,
      "text": "మహిళ, గుమ్మ, వనిత - మొదలైన వాటి అర్థం అ (3)"
    },
    {
      "row": 13,
      "number": 27,
      "text": "మొదట పార్వతి పైన మోహంపెంచుకున్న నీచులు (4)"
    },
    {
      "row": 14,
      "number": 30,
      "text": "సావకాశంగా వెళ్ళే చక్కని పాఠశాల (4)"
    },
    {
      "row": 15,
      "number": 31,
      "text": "విస్తృతమైన భూమి (3)"
