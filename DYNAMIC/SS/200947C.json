  "rows": [
    {
      "leftNumber": "18,40",
      "leftText": "ఆకె",
      "rightNumber": 1,
      "rightText": "భాండము"
    },
    {
      "leftNumber": 5,
      "leftText": "గర్భగుడి వుండేది",
      "rightNumber": 2,
      "rightText": "ఆకారంతో పాపనాశనం"
    },
    {
      "leftNumber": 7,
      "leftText": "కొందరికి కఠినం, కొందరికి కులాసా",
      "rightNumber": 3,
      "rightText": "డిటెక్టివులు తీసేది"
    },
    {
      "leftNumber": 9,
      "leftText": "డైరెక్షన్",
      "rightNumber": 4,
      "rightText": "విద్యుచ్ఛక్తి కొలమానాలు"
    },
    {
      "leftNumber": 10,
      "leftText": "మంచి యోధుడా (తలకిందులు)",
      "rightNumber": 5,
      "rightText": "వారం శెలవు"
    },
    {
      "leftNumber": 12,
      "leftText": "ఉపయోగించి",
      "rightNumber": 19,
      "rightText": null
    },
    {
      "leftNumber": 13,
      "leftText": "మొదటి వేల్పు వయస్సు",
      "rightNumber": 6,
      "rightText": "పాత్ర"
    },
    {
      "leftNumber": 15,
      "leftText": "గృహాలు",
      "rightNumber": 7,
      "rightText": "రాజకీయ నాయకుని ఇంటి పేరు"
    },
    {
      "leftNumber": 16,
      "leftText": "విద్య ఒక వేదం",
      "rightNumber": 8,
      "rightText": "దయచెయ్యండి (బైటికి కాదు లోనికి)"
    },
    {
      "leftNumber": 17,
      "leftText": "ప్రాణహానికి పెట్టింది పేరు",
      "rightNumber": 11,
      "rightText": "భయంతోనే ఇది"
    },
    {
      "leftNumber": 18,
      "leftText": "ఉదకమండలం",
      "rightNumber": 14,
      "rightText": "సూర్యుడుంటే ఇదెందుకు?"
    },
    {
      "leftNumber": 20,
      "leftText": "భూమి మన్నింపు",
      "rightNumber": 15,
      "rightText": "జీవితంలో తప్పనిది"
    },
    {
      "leftNumber": 22,
      "leftText": "సంశయం",
      "rightNumber": 18,
      "rightText": "కొందరి వుపన్యాసాలు"
    },
    {
      "leftNumber": 23,
      "leftText": "ఒక ప్రేమికుడు",
      "rightNumber": 19,
      "rightText": "ఒక పగలు, ఒక రాత్రి"
    },
    {
      "leftNumber": 25,
      "leftText": "ఒకడు, ఇంకొకడు కలిసి విష్ణు వాహనం",
      "rightNumber": 21,
      "rightText": "వజ్రాలు"
    },
    {
      "leftNumber": 27,
      "leftText": "మాటి మాటికి",
      "rightNumber": 22,
      "rightText": "మెరుపు"
    },
    {
      "leftNumber": 29,
      "leftText": "విరాజితం వృత్తం",
      "rightNumber": 23,
      "rightText": "అరిషడ్వర్గాలలోనిది"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 24,
      "rightText": "తండుల కణం"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 26,
      "rightText": "జబ్బు మరు జన్మలోనే"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 28,
      "rightText": "ఇల్లు"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 31,
      "rightText": "మచ్చ చెరగదు"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 32,
      "rightText": "ఆగు! ఖలునికి వెల్లవిషం"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 30,
      "rightText": "చెవిని"
    }
  ],
