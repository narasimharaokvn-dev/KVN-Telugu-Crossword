{
  "sheetName": "200644",
  "identity": "200644C",
  "rows": [
    {
      "leftNumber": "15,30",
      "leftText": "ఈ పత్రం లేతది",
      "rightNumber": 1,
      "rightText": "మాట, పాట"
    },
    {
      "leftNumber": 7,
      "leftText": "చరిత్ర పరిశోధకులకు ఉపకరిస్తుంది",
      "rightNumber": 2,
      "rightText": "నడిచే నాలుగో వంతు"
    },
    {
      "leftNumber": 8,
      "leftText": "ఈ యింటికి మరో రెండు",
      "rightNumber": 3,
      "rightText": "దీని వెన్న చంద్రుడు"
    },
    {
      "leftNumber": 10,
      "leftText": "ఇది కానిది",
      "rightNumber": 4,
      "rightText": "కష్టపడి విప్పి, తర్వాత తలలు కలిపి"
    },
    {
      "leftNumber": 11,
      "leftText": "ఒక తిధి (8 మైనస్ 1)",
      "rightNumber": 5,
      "rightText": "ఇది లభ్యమవుతుంది"
    },
    {
      "leftNumber": 13,
      "leftText": "దీని భర్త దీన్ని మోస్తున్నాడు",
      "rightNumber": 5,
      "rightText": "లాగు"
    },
    {
      "leftNumber": 14,
      "leftText": "చిక్కు",
      "rightNumber": 6,
      "rightText": "కలువ, కొలను"
    },
    {
      "leftNumber": 15,
      "leftText": "లో గేయం",
      "rightNumber": 9,
      "rightText": "గు"
    },
    {
      "leftNumber": 16,
      "leftText": "భారత భూపతి",
      "rightNumber": 10,
      "rightText": "ఎవరివి వాళ్ళని"
    },
    {
      "leftNumber": 18,
      "leftText": "వైశ్యుల లెక్కలో ఒకటి",
      "rightNumber": 12,
      "rightText": "అలనాటి ఆంధ్రావని"
    },
    {
      "leftNumber": 21,
      "leftText": "ఆమ్రేడిస్తే పరుగెత్తడం",
      "rightNumber": 15,
      "rightText": "ఆద్యంతాలు"
    },
    {
      "leftNumber": 2,
      "leftText": "జీవిత",
      "rightNumber": 17,
      "rightText": "- పడతారేమో, జాగ్రత్త?"
    },
    {
      "leftNumber": 24,
      "leftText": "స్తన శల్యం లాంటిది",
      "rightNumber": 19,
      "rightText": "బురద నెరిసిందా?"
    },
    {
      "leftNumber": 25,
      "leftText": "చెట్టుమీద చెట్టు",
      "rightNumber": 20,
      "rightText": "ఈ నిప్పు 3లో వుందంటారు"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 22,
      "rightText": "గడ్డికి నేస్తం?"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 23,
      "rightText": "ఒకనాటి గొప్ప ఆయుధం"
    }
  ],
