{
  "sheetName": "180416",
  "identity": "180416C",
  "rows": [
    {
      "leftNumber": 1,
      "leftText": "కాబట్టి ఎటు చూసినా...",
      "rightNumber": 1,
      "rightText": "నారద భోజనం"
    },
    {
      "leftNumber": 3,
      "leftText": "హిందీలో ప్రజలు",
      "rightNumber": 2,
      "rightText": "ఈవారు ధనవంతులు"
    },
    {
      "leftNumber": 4,
      "leftText": "చూడు 4 నిలువు",
      "rightNumber": 4,
      "rightText": "నిలువైనా అడ్డమైనా ఈ చోటనే."
    },
    {
      "leftNumber": 6,
      "leftText": "సగం ఇవతల తల తిరిగిన తీగ",
      "rightNumber": 5,
      "rightText": "జిత్తులమారి"
    },
    {
      "leftNumber": 8,
      "leftText": "సినిమాలో తిరుగు టపా, రేడియోలో కూడా",
      "rightNumber": 7,
      "rightText": "22 నిలువుకు పర్యాయపదం"
    },
    {
      "leftNumber": 9,
      "leftText": "రామకృష్ణ పరమ ఇది.",
      "rightNumber": 8,
      "rightText": "ఒక సూత్రకారుడు"
    },
    {
      "leftNumber": 11,
      "leftText": "అయిదుగురిలో ఆఖరిది. ఎనమండుగురిలో మొదటిది.",
      "rightNumber": 10,
      "rightText": "3తో కలసి మన పార్లమెంటు"
    },
    {
      "leftNumber": 12,
      "leftText": "వాళ్ళయొక్క నీళ్ళు",
      "rightNumber": 12,
      "rightText": "వామనుడి సంతకం ప్రారంభాలే ఇల్లు"
    },
    {
      "leftNumber": 13,
      "leftText": "కుంకుమ ఉంచే నక్షత్రం.",
      "rightNumber": 14,
      "rightText": "నాలుక నరస మార్పు"
    },
    {
      "leftNumber": 15,
      "leftText": "రెండో ఊపిరి",
      "rightNumber": 16,
      "rightText": "పులి"
    },
    {
      "leftNumber": 17,
      "leftText": "ఆహ్వానపత్రిక నిన్నేమంటుంది?",
      "rightNumber": 20,
      "rightText": "నిత్యబహువచనం బేబీకి అవసరం."
    },
    {
      "leftNumber": 18,
      "leftText": "శూన్యం ఒక ఇంగ్లీషు అచ్చు.",
      "rightNumber": 21,
      "rightText": "రోడ్డు మరమత్తు"
    },
    {
      "leftNumber": 19,
      "leftText": "అరసున్న చేర్చితే అంగీకారం",
      "rightNumber": 22,
      "rightText": "స్త్రీ"
    },
    {
      "leftNumber": 20,
      "leftText": "మంగళగిరిలో దొరికేదా?",
      "rightNumber": 23,
      "rightText": "తైలానికి మూలం."
    },
    {
      "leftNumber": 22,
      "leftText": "సంస్కృతంలో అంటారు ఈ పుకారు",
      "rightNumber": 24,
      "rightText": "ఉదాహరణకు ఆకాశవాణి"
    },
    {
      "leftNumber": 24,
      "leftText": "ఎవరేలుతున్నా లోపల దొరికేది చీకటే.",
      "rightNumber": 27,
      "rightText": "నిమిషాని కరవై"
    },
    {
      "leftNumber": 25,
      "leftText": "ఖరీదైన లోహం.",
      "rightNumber": 28,
      "rightText": "ఇది రూపాయల రూపంలోనే ఉండక్కరలేదు."
    },
    {
      "leftNumber": 26,
      "leftText": "ఒకటీ, అయిదు సున్నలు.",
      "rightNumber": 30,
      "rightText": "అబ్జాక్షి మేను ఆననాకార రహితం."
    },
    {
      "leftNumber": 28,
      "leftText": "భూమి ఖరీదు",
      "rightNumber": null,
      "rightText": null
    },
    {
      "leftNumber": 29,
      "leftText": "పోలేని పోతన స్వకీయం.",
      "rightNumber": null,
      "rightText": null
    },
    {
      "leftNumber": 31,
      "leftText": "ఆలోచన చాలాదూరం",
      "rightNumber": null,
      "rightText": null
    },
    {
      "leftNumber": 32,
      "leftText": "ఇంగ్లీషు నాటక ప్రారంభంలో ఎవరికీ గెలుపు లేదు.",
      "rightNumber": null,
      "rightText": null
    },
    {
      "leftNumber": 33,
      "leftText": "లోనికి చూస్తే కొనగలుగు వారికి దొరుకుతాయి.",
      "rightNumber": null,
      "rightText": null
    }
  ],
