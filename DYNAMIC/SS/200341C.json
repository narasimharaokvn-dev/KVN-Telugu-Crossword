{
  "sheetName": "200341",
  "identity": "200341C",
  "rows": [
    {
      "leftNumber": 4,
      "leftText": "వన వర్ణనకి ప్రారంభం (మన ప్రబంధాలలో చేరుతు",
      "rightNumber": 1,
      "rightText": "చలించక"
    },
    {
      "leftNumber": 7,
      "leftText": "మూకీలు మొగాల మీద కనిపిస్తాయి",
      "rightNumber": 2,
      "rightText": "ఉజ్వలాగమనం"
    },
    {
      "leftNumber": 8,
      "leftText": "కొస చిరిగిన కంచుకం",
      "rightNumber": 3,
      "rightText": "పెట్టుబడిదారు?"
    },
    {
      "leftNumber": 10,
      "leftText": "దీని తర్వాత శుభం",
      "rightNumber": 4,
      "rightText": "బహువచనంలో 23"
    },
    {
      "leftNumber": 11,
      "leftText": "సాహిత్య విమర్శ",
      "rightNumber": 5,
      "rightText": "తోక తెగిన దుష్టుడు"
    },
    {
      "leftNumber": 13,
      "leftText": "మేఘం ఎగిరేది",
      "rightNumber": 6,
      "rightText": "అప్పకవి ఒప్పుకోనిది"
    },
    {
      "leftNumber": 14,
      "leftText": "కవిత్వం లాగ కరతాళ ధ్వనులు",
      "rightNumber": 9,
      "rightText": "సాధారణంగా గ్రంధాలలో కన్పించేది"
    },
    {
      "leftNumber": 15,
      "leftText": "బాక్సాఫీసు బద్దలు కొడతాయి",
      "rightNumber": 10,
      "rightText": "వ్యక్తిత్వం చాటుకో"
    },
    {
      "leftNumber": 16,
      "leftText": "ఒక విభక్తి ప్రత్యయం",
      "rightNumber": 12,
      "rightText": "నూరు కాకుల్ని తిన్న రాబందు"
    },
    {
      "leftNumber": 18,
      "leftText": "ఆకలి (దానికే ఇది తెలియదు)",
      "rightNumber": 15,
      "rightText": "1,2,3,4, వగైరా! ఎలాగున్నాయి?"
    },
    {
      "leftNumber": 21,
      "leftText": "నిశిలో, రోదసిలో కనిపించేది",
      "rightNumber": 17,
      "rightText": "శుభకార్యాలలో పంచి పెట్టేది"
    },
    {
      "leftNumber": 22,
      "leftText": "వచనానికి అప్పకవి",
      "rightNumber": 19,
      "rightText": "భరతుడికి రాముడు, సహదేవుడికి భీముడు"
    },
    {
      "leftNumber": 24,
      "leftText": "కొందరి బ్రతుకులు",
      "rightNumber": 20,
      "rightText": "అనసూయకు లేనిది"
    },
    {
      "leftNumber": 25,
      "leftText": "యౌవనము (కొద్దిగా చెడింది)",
      "rightNumber": 22,
      "rightText": "అర్ధంలేని అక్షరాలు మంచి గదుల్లోనే"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 23,
      "rightText": "ఏకవచనంలో 4 నిలువు"
    }
  ],
