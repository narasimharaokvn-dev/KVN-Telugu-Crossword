      "rightText": "కావ్యనాయిక"
    },
    {
      "leftNumber": 23,
      "leftText": "మన రాష్ట్రపు దేహళి",
      "rightNumber": 21,
      "rightText": "సర్కస్ పిల్ల"
    },
    {
      "leftNumber": 25,
      "leftText": "తోటకూరది, తలక్రిందులు",
      "rightNumber": 22,
      "rightText": "ప్రసవించె"
