      "rightNumber": 1,
      "rightText": "జ్వాలాముఖి కవిత్వం"
    },
    {
      "leftNumber": 5,
      "leftText": "కోరి",
      "rightNumber": 2,
      "rightText": "కాలకం పుట్టుమచ్చ"
    },
    {
      "leftNumber": 7,
      "leftText": "నిజం ఉన్న చక్కదనం",
      "rightNumber": 3,
      "rightText": "దీని కిందికే గడ"
    },
    {
      "leftNumber": 9,
      "leftText": "ఆఫీసులో, భరతనాట్యంలో",
      "rightNumber": 4,
      "rightText": "వెంటనే"
    },
    {
      "leftNumber": 10,
      "leftText": "కొండమ్మ",
      "rightNumber": 5,
      "rightText": "బాళికి తాళింది 16 చూడుడు"
    },
    {
      "leftNumber": 12,
      "leftText": "విసురు",
      "rightNumber": 6,
      "rightText": "రెండో 12 గంటలు"
    },
    {
      "leftNumber": 13,
      "leftText": "నాలు నమస్కారాలు",
      "rightNumber": 7,
      "rightText": "నాపురం లేనిది"
    },
    {
      "leftNumber": 15,
      "leftText": "కోరు మోసకాడు",
      "rightNumber": 8,
      "rightText": "ఇంగ్లీషులో ప్రవహించేది, తెలుగులో వికసించేది"
    },
    {
      "leftNumber": 16,
      "leftText": "బింబం నెలకొకసారి",
      "rightNumber": 11,
      "rightText": "వని కునికి పట్టు"
    },
    {
      "leftNumber": 17,
      "leftText": "ఈ పత్రిక",
      "rightNumber": 14,
      "rightText": "విజయ 15 పండుగ"
    },
    {
      "leftNumber": 18,
      "leftText": "సమూహం",
      "rightNumber": 15,
      "rightText": "పండుగ రోజులు"
    },
    {
      "leftNumber": 20,
      "leftText": "తనం ధూర్తగుణం",
      "rightNumber": 18,
      "rightText": "అందెల రవళి"
    },
    {
      "leftNumber": 22,
      "leftText": "నోటికూత",
