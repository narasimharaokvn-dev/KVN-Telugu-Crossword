  "rows": [
    {
      "leftNumber": 3,
      "leftText": "పడతుల పక్షపాతి",
      "rightNumber": 1,
      "rightText": "తోకతెగిన ఋతువు"
    },
    {
      "leftNumber": 5,
      "leftText": "16 నక్సలిజానికి నాంది.",
      "rightNumber": 2,
      "rightText": "వెండిది సాధారణంగా రెండోది"
    },
    {
      "leftNumber": 6,
      "leftText": "అల్లసాని అగ్రహారం",
      "rightNumber": 3,
      "rightText": "వెన్నెల తిండి"
    },
    {
      "leftNumber": 8,
      "leftText": "ఆంధ్రదేశం అన్నం",
      "rightNumber": 4,
      "rightText": "చుట్టూ నీళ్ళు"
    },
    {
      "leftNumber": 9,
      "leftText": "బాలకృష్ణుడు",
      "rightNumber": 5,
      "rightText": "అంటే రంగులు పులమడమా?"
    },
    {
      "leftNumber": 11,
      "leftText": "కనుక",
      "rightNumber": 7,
      "rightText": "చప్పుడు వింటిని"
    },
    {
      "leftNumber": 13,
      "leftText": "శ్రుతి విభాగం",
      "rightNumber": 8,
      "rightText": "వయో విశేషం"
    },
    {
      "leftNumber": 15,
      "leftText": "నాటకానికి తెర ఎత్తడం",
      "rightNumber": 10,
      "rightText": "రాజమండ్రిలో ట్రాజెడీ"
    },
    {
      "leftNumber": 16,
      "leftText": "చూడు 5 అడ్డం",
      "rightNumber": 12,
      "rightText": "శ్రావణ మేఘం"
    },
    {
      "leftNumber": 17,
      "leftText": "ముగ్గురు కవుల ముద్దుబిడ్డ",
      "rightNumber": 14,
      "rightText": "కూడింది."
    },
    {
      "leftNumber": 19,
      "leftText": "ఆకర్షించి",
      "rightNumber": 15,
      "rightText": "నమస్కారం"
    },
    {
      "leftNumber": 22,
      "leftText": "నావి (బహువచనం)",
      "rightNumber": 17,
      "rightText": "కూచిపూడి కలాపం"
    },
    {
      "leftNumber": 23,
      "leftText": "జనానాలలో కనిపించేది",
      "rightNumber": 18,
      "rightText": "రవి కవీంద్రుని 15 అడ్డం"
    },
    {
      "leftNumber": 25,
      "leftText": "విజాతి",
      "rightNumber": 20,
      "rightText": "అలంక్రియ"
    },
    {
      "leftNumber": 26,
      "leftText": "జంట",
      "rightNumber": 21,
      "rightText": "ప్రోగు"
    },
    {
      "leftNumber": 28,
      "leftText": "హైదరాబాదులో ఆఖరివాడు",
      "rightNumber": 23,
      "rightText": "పిట్ట గుడ్లగూబ"
    },
    {
      "leftNumber": 30,
      "leftText": "తగ్గు",
