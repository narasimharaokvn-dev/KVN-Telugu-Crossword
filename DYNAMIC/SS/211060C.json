  "rows": [
    {
      "leftNumber": 3,
      "leftText": "ఆ కెరటం",
      "rightNumber": 1,
      "rightText": "తాళ సప్తకంలో ఒకటి"
    },
    {
      "leftNumber": 5,
      "leftText": "వరూధిని వీణ దేనికి మేళం?",
      "rightNumber": 2,
      "rightText": "గ్రహంలో కుకని తల పెడితే భారతపాత్ర"
    },
    {
      "leftNumber": 6,
      "leftText": "కనరానిది కలిసి రావచ్చు.",
      "rightNumber": 3,
      "rightText": "ఎనమిది ముందర ఆద్యక్షరము"
    },
    {
      "leftNumber": 8,
      "leftText": "ఆకొన్న కంచెకు ఆహారం",
      "rightNumber": 4,
      "rightText": "మూడు మాత్రలు"
    },
    {
      "leftNumber": 9,
      "leftText": "అధమం",
      "rightNumber": 5,
      "rightText": "ఇది నేనన్నది"
    },
    {
      "leftNumber": 11,
      "leftText": "పాదితో పేలుతుంది",
      "rightNumber": 7,
      "rightText": "పడడం శ్రమ"
    },
    {
      "leftNumber": 13,
      "leftText": null,
      "rightNumber": 8,
      "rightText": "భవుడు మన్మధుడు"
    },
    {
      "leftNumber": 25,
      "leftText": "జానకీ ఊర్మిళా",
      "rightNumber": 10,
      "rightText": "మధ్యమ పుష్టిలేని ఆస్థాన కవి"
    },
    {
      "leftNumber": 15,
      "leftText": "అమ్ము",
      "rightNumber": 12,
      "rightText": "ధ్వని విశేషం"
    },
    {
      "leftNumber": 16,
      "leftText": "అభినందనకీ, ఆప్యాయానికి",
      "rightNumber": 14,
      "rightText": "సారీ (బహువచనం)"
    },
    {
      "leftNumber": 17,
      "leftText": "అంటుకుంటే ప్రమాదం",
      "rightNumber": 15,
      "rightText": "ఆమ్రేడిస్తే సభలో కేకలు"
    },
    {
      "leftNumber": 19,
      "leftText": "అటు వైపునుంచి వచ్చేది",
      "rightNumber": 17,
      "rightText": "నక్క అతిధి"
    },
    {
      "leftNumber": 22,
      "leftText": "మాయించడం మంచిది కాదు",
      "rightNumber": 18,
      "rightText": "ఎలక్షన్ల తుది ఘట్టం?"
