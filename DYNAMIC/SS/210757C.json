{
  "sheetName": "210757",
  "identity": "210757C",
  "rows": [
    {
      "leftNumber": 3,
      "leftText": "ప్రమాణమా?",
      "rightNumber": 1,
      "rightText": "అహింసా ప్రవక్త ఆశ్రమం"
    },
    {
      "leftNumber": 5,
      "leftText": null,
      "rightNumber": 2,
      "rightText": "కోట చరిత్ర ప్రసిద్ధం"
    },
    {
      "leftNumber": 6,
      "leftText": "నిలువు సర్కారుకి కట్టేది",
      "rightNumber": 3,
      "rightText": "దగ్గర బంధువు"
    },
    {
      "leftNumber": 7,
      "leftText": "-గా వినమంటారు",
      "rightNumber": 4,
      "rightText": "గడచిన సంవత్సరం"
    },
    {
      "leftNumber": 9,
      "leftText": "కొన్ని క్రియలకు లేదు",
      "rightNumber": 5,
      "rightText": "రావడం శుక్ల పక్షంలో"
    },
    {
      "leftNumber": 10,
      "leftText": "సోలిన కన్ను (తలక్రిందులు)",
      "rightNumber": 6,
      "rightText": "చూ. 5 అడ్డం"
    },
    {
      "leftNumber": 12,
      "leftText": "జపాన్ లో ఉదయిస్తే జర్మనీలో కనిపించదు",
      "rightNumber": 7,
      "rightText": "19 ఎన్నో అంతరించాయి"
    },
    {
      "leftNumber": 13,
      "leftText": "ఉదకంతో దానం",
      "rightNumber": 8,
      "rightText": "పెట్ట"
    },
    {
      "leftNumber": 15,
      "leftText": "“భారతీయ” వాద్యం",
      "rightNumber": 11,
      "rightText": "భీముని విష్ణుమూర్తి"
    },
    {
      "leftNumber": 16,
      "leftText": "నా పురం ఢిల్లీ",
      "rightNumber": 14,
      "rightText": "ఇలకాదు అల"
    },
    {
      "leftNumber": 17,
      "leftText": "కథలకి గమ్యం",
      "rightNumber": 15,
      "rightText": "ఇదీ అదే"
    },
    {
      "leftNumber": 18,
      "leftText": "అచ్చ తెలుగులో నిదర్శనం",
      "rightNumber": 18,
      "rightText": "ఫోటోలో లేదు, సినిమాలో ఉం"
    },
    {
      "leftNumber": 20,
      "leftText": "కర్పూర తద్భవం",
      "rightNumber": 19,
      "rightText": "చూ. 7 నిలువు"
    },
    {
      "leftNumber": 22,
      "leftText": "కాలం సత్యకాలం",
      "rightNumber": 21,
      "rightText": "రు"
    },
    {
      "leftNumber": 23,
      "leftText": "హిమసహితంగా కర్పూరం",
      "rightNumber": 22,
      "rightText": "ఒక శతక మకుటాంతం"
    },
    {
      "leftNumber": 25,
      "leftText": "దారి అటునుంచి ఇటు",
      "rightNumber": 23,
      "rightText": "అగ్నికి తల్లి"
    },
    {
      "leftNumber": 27,
      "leftText": "ఆ తర్వాత",
      "rightNumber": 24,
      "rightText": "18 నిలువు దతుదిమొదళ్ళు"
    },
    {
      "leftNumber": 29,
      "leftText": "పోరు",
      "rightNumber": 26,
      "rightText": "స్ఫురించు"
    },
    {
      "leftNumber": 31,
      "leftText": "హిందీలో చెప్పు",
      "rightNumber": 28,
      "rightText": "హెచ్చరిక"
    },
    {
      "leftNumber": 32,
      "leftText": "రతా",
      "rightNumber": 30,
      "rightText": "ఈ ఇల్లు భారతంలో ఉంది"
    }
  ],
