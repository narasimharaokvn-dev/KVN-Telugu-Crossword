{
  "sheetName": "180315",
  "identity": "180315C",
  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "ఈ సభ్యుల బృందం వల్ల లోక మిటీవల మారిందా?"
    },
    {
      "row": 2,
      "number": 3,
      "text": "సైన్యం తిరుగుబాటుతో ప్రభుత్వ పతనం"
    },
    {
      "row": 3,
      "number": 4,
      "text": "ఇదంతా కృ.శా. అక్షయపాత్ర"
    },
    {
      "row": 4,
      "number": 6,
      "text": "సాధారణంగా తాత్పర్యానికి ముందు"
    },
    {
      "row": 5,
      "number": 8,
      "text": "ఆచ్ఛాదించు"
    },
    {
      "row": 6,
      "number": 9,
      "text": "ఇది పండు కాదు, కాయ"
    },
    {
      "row": 7,
      "number": 11,
      "text": "వేలంలో వినిపిస్తాయి."
    },
    {
      "row": 8,
      "number": 12,
      "text": "ముందు వెనకా చూడకుండా ఆరంభించడు చూసి క్రీడించు"
    },
    {
      "row": 9,
      "number": 13,
      "text": "సుకుమారికోసం తిప్పుకో, మలిపుట"
    },
    {
      "row": 10,
      "number": 15,
      "text": "నవరుచులలో ఒక గరువ మారింది"
    },
    {
      "row": 11,
      "number": 17,
      "text": "ఇంగ్లీష్ కంపనీకి హ్రస్వరూపం"
    },
    {
      "row": 12,
      "number": 18,
      "text": "చెయ్యి చతుర్థీ విభక్తి"
    },
    {
      "row": 13,
      "number": 19,
      "text": "తీసుకురా"
    },
    {
      "row": 14,
      "number": 20,
      "text": "అరగనిది, తరగనిది"
    },
    {
      "row": 15,
      "number": 22,
      "text": "పెద్ద రైతుకు ట్రాక్టర్లు, చిన్న సేద్యగాడికి ఇది?"
    },
    {
      "row": 16,
      "number": 24,
      "text": "ఇది ఆడకపోతే ప్రమాదం"
    },
    {
      "row": 17,
      "number": 25,
      "text": "ఓరీ, తులువా! దాచిన పద్ధతులు బయటపెట్టు"
    },
    {
      "row": 18,
      "number": 26,
      "text": "కలత నిద్రలో మధుర గాయని"
    },
    {
      "row": 19,
      "number": 28,
      "text": "నాంచారి?"
    },
    {
      "row": 20,
      "number": 29,
      "text": "దీనికి తకారం ఇతడు రాసేదవుతుంది"
    },
    {
      "row": 21,
      "number": 31,
      "text": "ఒక రాగవిశేషం"
    },
    {
      "row": 22,
      "number": 32,
      "text": "ఇన్ఫ్లుయెన్జా"
    },
    {
      "row": 23,
      "number": 33,
      "text": "రేచుక్క, పగటిచుక్క"
    }
  ],
  "downEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "తెలుగులో కవిత్వం"
    },
    {
      "row": 2,
      "number": 2,
      "text": "ఒకటీ ఇంకొకటీ"
    },
    {
      "row": 3,
      "number": 4,
      "text": "ఇది ఇచ్చేవాడు వైద్యుడా?"
    },
    {
      "row": 4,
      "number": 5,
      "text": "పోయిన యేడు"
    },
    {
      "row": 5,
      "number": 7,
      "text": "పునుక తాలుపు వేలుపు"
    },
    {
      "row": 6,
      "number": 8,
      "text": "తుదిలేని వడ్డీతో మొదలులేని రూకలు. ఫలితం ఒక పువ్వు"
    },
    {
      "row": 7,
      "number": 10,
      "text": "బాణం తిరుగుబాటు"
    },
    {
      "row": 8,
      "number": 12,
      "text": "ఇందులో సగం"
    },
    {
      "row": 9,
      "number": 14,
      "text": "మకార పంచకంలో మత్తు కలిగించేది"
    },
    {
      "row": 10,
      "number": 16,
      "text": "గాడిద చేసేదా?"
    },
    {
      "row": 11,
      "number": 20,
      "text": "ఈ గుడ్డలు గొంతులు కోయడానికా?"
    },
    {
      "row": 12,
      "number": 21,
      "text": "... హఠావో అంటే పోతుందా?"
    },
    {
      "row": 13,
      "number": 22,
      "text": "స్త్రీలకిది సింగారమంటారు"
    },
    {
      "row": 14,
      "number": 23,
      "text": "లింగభేదంతో నిమిత్తంలేకుండా అందరూ కనేది"
    },
    {
      "row": 15,
      "number": 24,
      "text": "పరీక్షా? కెమిస్ట్రీలో కావచ్చు"
    },
    {
      "row": 16,
      "number": 27,
      "text": "అపరాధాలు"
    },
    {
      "row": 17,
      "number": 28,
      "text": "మెరీనా"
    },
    {
      "row": 18,
      "number": 30,
      "text": "ఆవిరియంత్రంలో అగుపించే పువ్వు"
    }
  ]
}