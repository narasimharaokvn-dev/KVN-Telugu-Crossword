  "crossEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "క్రికెట్లోకాలికి బుద్ధిచెప్పడాలు కాబోలు!"
    },
    {
      "row": 2,
      "number": 3,
      "text": "లక్ష్మీపతి కవిసార్వభౌముడు."
    },
    {
      "row": 3,
      "number": 7,
      "text": "32లో కామి లేడు; భూమి తిరగబడింది."
    },
    {
      "row": 4,
      "number": 8,
      "text": "కొమ్ముల్లేని కులుకు కోపానిక్కారణం."
    },
    {
      "row": 5,
      "number": 9,
      "text": "చదరంగంలో నాలుగో వంతు."
    },
    {
      "row": 6,
      "number": 12,
      "text": "గౌతమబుద్దుని మహాప్రస్థానం."
    },
    {
      "row": 7,
      "number": 15,
      "text": "క్షయకి సూచన."
    },
    {
      "row": 8,
      "number": 16,
      "text": "సంపద విశాఖపట్టణంలో దొరకొచ్చు."
    },
    {
      "row": 9,
      "number": 17,
      "text": "తిరగబడే గగనంలో పక్షి"
    },
    {
      "row": 10,
      "number": 20,
      "text": "రమణాస్థాన్ మహర్షి ఇంటి పేరు."
    },
    {
      "row": 11,
      "number": 21,
      "text": "(మిలనేకా)మారువేషంలో ఒక రాక్షసుడు."
    }
  ],
  "downEntries": [
    {
      "row": 1,
      "number": 1,
      "text": "71 తిరగెయ్యాలి"
    },
    {
      "row": 2,
      "number": 2,
      "text": "20 తల. దేవుడి యిల్లు."
    },
    {
      "row": 3,
      "number": 4,
      "text": "బొడ్డులో విషం?"
    },
    {
      "row": 4,
      "number": 5,
      "text": "ప్రథమా విభక్తి."
    },
    {
      "row": 5,
      "number": 6,
      "text": "మన కవితా పితామహుణ్ణి వికటకవి ఇలా పిలిచాడు."
    },
    {
      "row": 6,
      "number": 10,
      "text": "ఇదో ఎడారి"
    },
    {
      "row": 7,
      "number": 11,
      "text": "ఆంతా మరణించడంలో ఉండి నీళ్ళల్లో ఉంటుంది."
    },
    {
      "row": 8,
      "number": 13,
      "text": "ప్రజానాట్యమండలి వారి నాటకం (మొదట ప్రశ్నించు!)"
    },
    {
      "row": 9,
      "number": 14,
      "text": "ఏమిట? గమనంలో తిరిగి చూడు మగతనానికి."
    },
    {
      "row": 10,
      "number": 18,
      "text": "సూలకాయుణ్ణి దీనితో పోలుస్తారు."
    },
    {
      "row": 11,
      "number": 19,
      "text": "సగం ఇవతల సగం ఆవతల"
