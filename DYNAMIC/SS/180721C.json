{
  "sheetName": "180721",
  "identity": "180721C",
  "rows": [
    {
      "leftNumber": 1,
      "leftText": "ఎక్కడుంది రాజమండ్రి",
      "rightNumber": 1,
      "rightText": "రేపల్లె ఆవుల మంద"
    },
    {
      "leftNumber": 7,
      "leftText": "దైత్యుల తల్లి",
      "rightNumber": 2,
      "rightText": "20లో సగం"
    },
    {
      "leftNumber": 8,
      "leftText": "ధాన్యం అందరిలో లేదు ఎవరిలోనో ఉంది",
      "rightNumber": 3,
      "rightText": "ఒక ఆలంకారిక మతం"
    },
    {
      "leftNumber": 9,
      "leftText": "శ్రీకారంతో ఒక దేశ",
      "rightNumber": 4,
      "rightText": "ఆశీస్సులు"
    },
    {
      "leftNumber": 11,
      "leftText": "పూర్వ జన్మలకిది ఉంటుందట",
      "rightNumber": 5,
      "rightText": "సమయం"
    },
    {
      "leftNumber": 12,
      "leftText": "సుమీ అని కూడా అనవచ్చు",
      "rightNumber": 6,
      "rightText": "అప్పుడే పుట్టిన శిశువు వయస్పుకావచ్చు"
    },
    {
      "leftNumber": 13,
      "leftText": "సిద్ధాంతపూర్వ పక్షాలు?",
      "rightNumber": 10,
      "rightText": "... అనునామంబు నీటి కాకికి లేదే!"
    },
    {
      "leftNumber": 15,
      "leftText": "తక్కువ, లోటు",
      "rightNumber": 14,
      "rightText": "కొనగోళ్ళకు పెద్దనార్యుని విశేషణం"
    },
    {
      "leftNumber": 18,
      "leftText": "ఇంగ్లీషులో అలాగా కాని హిందీలో గోబద్ధం కాదు",
      "rightNumber": 16,
      "rightText": "గులేబకావళిలో ఊరు తిరగబడింది."
    },
    {
      "leftNumber": 19,
      "leftText": "తమరు జబ్బుపడితే ఏముంది?",
      "rightNumber": 17,
      "rightText": "పర్యవేక్షణ (తిరగబడింది)"
    },
    {
      "leftNumber": 21,
      "leftText": "పేదవాడు తిరగబడ్డ రికాబి!",
      "rightNumber": 20,
      "rightText": "నేటి సినిమాతార"
    },
    {
      "leftNumber": 23,
      "leftText": "తినగా తినగా తీపు",
      "rightNumber": 21,
      "rightText": "ఒక సంవత్సరం (అటునుంచి ఇటు)"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 22,
      "rightText": "ఋషభం, దైవతం"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 4,
      "rightText": null
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 25,
      "rightText": "పడినా, చేసినా మోసమే!"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 26,
      "rightText": "తినగా తినగా చేదు"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 27,
      "rightText": "సుడి (వెనుకబడి)"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 27,
      "rightText": "బండి బోల్తా పడింది"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 29,
      "rightText": "విరహం"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 28,
      "rightText": "నూయి (తిరగబడి)"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 30,
      "rightText": "శ్రీ శ్రీ కల్పన"
    }
  ],
