  "rows": [
    {
      "leftNumber": 1,
      "leftText": "నాలో సగం",
      "rightNumber": 2,
      "rightText": "ఆడదాని ఆద్యంతాలు కెరటం"
    },
    {
      "leftNumber": 2,
      "leftText": "పద్మార్కం",
      "rightNumber": 3,
      "rightText": "ఇతని మతంలో దేవుడు లేడు"
    },
    {
      "leftNumber": 5,
      "leftText": "ఇంగ్లీషు చెట్టు",
      "rightNumber": 4,
      "rightText": "అసంపూర్ణ గ్రంథం తొమ్మిదవది"
    },
    {
      "leftNumber": 6,
      "leftText": "రెండు లఘువులు",
      "rightNumber": 6,
      "rightText": "ఈ ఇల్లు భారతంలో తగలడింది"
    },
    {
      "leftNumber": 7,
      "leftText": "తిరగబడ్డ బంధువు",
      "rightNumber": 8,
      "rightText": "Koloo"
    },
    {
      "leftNumber": 9,
      "leftText": "7 భార్య 2",
      "rightNumber": 9,
      "rightText": "2లో 3 పాదం మొదలు"
    },
    {
      "leftNumber": 10,
      "leftText": "అటునుండి అమ్మాయి",
      "rightNumber": 10,
      "rightText": "ప్రధానేంద్రియం"
    },
    {
      "leftNumber": 12,
      "leftText": "వాద్య విశేషం",
      "rightNumber": 11,
      "rightText": "ఒక ఉభయచరం"
    },
    {
      "leftNumber": 14,
      "leftText": "తమర్ని ఏకవచనంలో",
      "rightNumber": 13,
      "rightText": "జనకుని జామాత"
    },
    {
      "leftNumber": 15,
      "leftText": "ఈ తగవు మధురవాణి సూచించింది",
      "rightNumber": 14,
      "rightText": "దీర్ఘం"
    },
    {
      "leftNumber": 17,
      "leftText": "మధ్యమ పాండవుడు",
      "rightNumber": 16,
      "rightText": "కృశ్చేవ్ పేరు"
    },
    {
      "leftNumber": 18,
      "leftText": "30 అడ్డంతో కలవ్వచ్చు",
      "rightNumber": 21,
      "rightText": "రే"
    },
    {
      "leftNumber": 19,
      "leftText": "ఇది లేని గది ఉంటుందా?",
