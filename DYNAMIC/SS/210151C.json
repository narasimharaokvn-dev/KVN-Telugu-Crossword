{
  "sheetName": "210151",
  "identity": "210151C",
  "rows": [
    {
      "leftNumber": 3,
      "leftText": "టాగూరు నవలలో నాస్తికుడు",
      "rightNumber": 1,
      "rightText": "అల్లసాని వాడకం అంతా చీకటి"
    },
    {
      "leftNumber": 5,
      "leftText": "ప్రాజెక్టు స్థలం",
      "rightNumber": 2,
      "rightText": "గాలిని గానం చేస్తుంది"
    },
    {
      "leftNumber": 7,
      "leftText": null,
      "rightNumber": 3,
      "rightText": "అడ్డు-విభజిస్తుంది"
    },
    {
      "leftNumber": 9,
      "leftText": "కుశ - నాటకం",
      "rightNumber": 4,
      "rightText": "ఈ మధ్యనే విడుదలయింది"
    },
    {
      "leftNumber": 10,
      "leftText": "భారత చక్రవర్తి",
      "rightNumber": 5,
      "rightText": "కొలమానం"
    },
    {
      "leftNumber": 12,
      "leftText": "ముందు చూస్తే ఇది?",
      "rightNumber": 6,
      "rightText": "తప్పక పాడాలి"
    },
    {
      "leftNumber": 13,
      "leftText": "చదరంగంలో డ్రా",
      "rightNumber": 7,
      "rightText": "డాక్యుమెంటరీ నిపుణుడు"
    },
    {
      "leftNumber": 15,
      "leftText": "బిందువు ఫుల్ స్టాప్ కాదు",
      "rightNumber": 8,
      "rightText": "వాలడం 7 అడ్డులో"
    },
    {
      "leftNumber": 16,
      "leftText": "పాండవులు వాడిన చెట్టు",
      "rightNumber": 11,
      "rightText": "కాలమానం"
    },
    {
      "leftNumber": 17,
      "leftText": "నిద్రపుచ్చేది నల్లమందు కాదు",
      "rightNumber": 14,
      "rightText": "ప్రాసించని ద్విపద"
    },
    {
      "leftNumber": 18,
      "leftText": "కొందరి కూతపదం",
      "rightNumber": 15,
      "rightText": "ఇటు కర్ర అటు రాయి"
    },
    {
      "leftNumber": 20,
      "leftText": "21 నిలువు పని కావలిస్తే పడవలసిందే",
      "rightNumber": 18,
      "rightText": "అతకార పురాణం చాలా బరువు"
    },
    {
      "leftNumber": 22,
      "leftText": "రం కలిస్తే ఓగిరం",
      "rightNumber": 19,
      "rightText": "మొదట ముందు పిదప వెనుక"
    },
    {
      "leftNumber": 23,
      "leftText": "నీటిలో నిప్పు పుట్టించేది",
      "rightNumber": 21,
      "rightText": "చూ. 21 అడ్డం"
    },
    {
      "leftNumber": 25,
      "leftText": "వస్తాదు.",
      "rightNumber": 22,
      "rightText": "ఊర్పు"
    },
    {
      "leftNumber": 27,
      "leftText": "చల్లని వెన్నెల రేయి",
      "rightNumber": 23,
      "rightText": "తెగిస్తారు కొందరు"
    },
    {
      "leftNumber": 29,
      "leftText": "రావణేశ్వరం",
      "rightNumber": 24,
      "rightText": "తేల్చుకుంటారు కొందరు"
    },
    {
      "leftNumber": 31,
      "leftText": "మీ కాహ్వానం",
      "rightNumber": 26,
      "rightText": "పెట్ట - మగడు?"
    },
    {
      "leftNumber": 32,
      "leftText": "పావలా వంతు శరీరాంగం",
      "rightNumber": 28,
      "rightText": "తెలుగు యతి"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 30,
      "rightText": "పడితే రొట్టె నేతిలో పడవచ్చు"
    }
  ],
