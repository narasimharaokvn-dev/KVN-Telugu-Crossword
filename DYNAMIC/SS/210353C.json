      "leftText": "ఇంకో ఈశ్వరి",
      "rightNumber": 7,
      "rightText": "నాటు వైద్యుడు?"
    },
    {
      "leftNumber": 3,
      "leftText": "ముక్కున ఉంటుంది",
      "rightNumber": 8,
