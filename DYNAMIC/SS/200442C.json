  "rows": [
    {
      "leftNumber": 4,
      "leftText": "విప్లవకవి తిరుగుబాటు",
      "rightNumber": 1,
      "rightText": "కస్తూరి అకటా వికటం"
    },
    {
      "leftNumber": 7,
      "leftText": "ఒక ఆటకు సంబంధించి -",
      "rightNumber": 2,
      "rightText": "పంట పండించేవాడు"
    },
    {
      "leftNumber": 8,
      "leftText": "జీవితానికి మరణం",
      "rightNumber": 3,
      "rightText": "చలితం, కలతపడింది."
    },
    {
      "leftNumber": 10,
      "leftText": "గోవిందం రెండు గణాలు",
      "rightNumber": 4,
      "rightText": "ఒక నది కల్లోలమయింది."
    },
    {
      "leftNumber": 11,
      "leftText": "వెదక దగ్గది",
      "rightNumber": 5,
      "rightText": "సమయం"
    },
    {
      "leftNumber": 13,
      "leftText": "ఆడు పక్షి",
      "rightNumber": 6,
      "rightText": "నీళ్ళధార"
    },
    {
      "leftNumber": 14,
      "leftText": "9",
      "rightNumber": 9,
      "rightText": "ఒక అలంకారికుని జీవితం"
    },
    {
      "leftNumber": 15,
      "leftText": "2\nలేదు",
      "rightNumber": 10,
      "rightText": "హాస్య రచయిత ఇంటి పేరు"
    },
    {
      "leftNumber": 16,
      "leftText": "ఆపద సమయంలో అరుపు",
      "rightNumber": 12,
      "rightText": "అల్లుడికి హాయి"
    },
    {
      "leftNumber": 18,
      "leftText": "ఎవరి వంతు? (వెదుక్కోవాలి)",
      "rightNumber": 15,
      "rightText": "దేశభక్తికి తుది కానుక"
    },
    {
      "leftNumber": 21,
      "leftText": "సుల్తాను సూది మొన",
      "rightNumber": 17,
      "rightText": "ఆనాడు తోకనుంచి తలదాకా"
    },
    {
      "leftNumber": 22,
      "leftText": "యోగబోధిని",
      "rightNumber": 19,
      "rightText": "కొంచెం నంచుకొన్న సెనగలు"
    },
    {
      "leftNumber": 24,
      "leftText": "ధనికుల నివాసాలు",
      "rightNumber": 20,
      "rightText": "వాంతి"
    },
    {
      "leftNumber": 25,
      "leftText": "పూర్తికాలేదు, అటుకాదు ఇటు",
      "rightNumber": 22,
      "rightText": "ఆశ్చర్యానికి, ప్రశంసకి"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 23,
      "rightText": "పువ్వులపని తలకిందులు"
