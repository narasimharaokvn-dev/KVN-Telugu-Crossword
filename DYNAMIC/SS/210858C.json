  "rows": [
    {
      "leftNumber": 3,
      "leftText": "ఆభరణం",
      "rightNumber": 1,
      "rightText": "జన చైనాకు 1949లో"
    },
    {
      "leftNumber": 5,
      "leftText": "ప్రార్థనకు ప్రారంభం",
      "rightNumber": 2,
      "rightText": "రారు అంటే అతిశయించు"
    },
    {
      "leftNumber": 7,
      "leftText": "చావకుంటే తినవచ్చు",
      "rightNumber": 3,
      "rightText": "సింహాలకు, జంతువులకు"
    },
    {
      "leftNumber": 9,
      "leftText": "ఆవు మనమరాలు",
      "rightNumber": 4,
      "rightText": "జమీందార్ల నౌకర్లు"
    },
    {
      "leftNumber": 10,
      "leftText": "కాలభాగం",
      "rightNumber": 6,
      "rightText": "కాని, ఎరుపు"
    },
    {
      "leftNumber": 12,
      "leftText": "ఫాషన్ తీక్షణత",
      "rightNumber": 6,
      "rightText": "చెట్టు, పెదవి"
    },
    {
      "leftNumber": 13,
      "leftText": "లోకువ",
      "rightNumber": 7,
      "rightText": "రా అంటే వచ్చేది"
    },
    {
      "leftNumber": 15,
      "leftText": "కాలంతో రాలేవి",
      "rightNumber": 8,
      "rightText": "ఎం కాదు"
    },
    {
      "leftNumber": 16,
      "leftText": "ఇకారం ఇంటికన్నా పదిలం",
      "rightNumber": 11,
      "rightText": "19 కొందరికి బూతుమాట"
    },
    {
      "leftNumber": 17,
      "leftText": "15, 23 అడ్డంలో పైసలు",
      "rightNumber": 14,
      "rightText": "వదులు కాదు"
    },
    {
      "leftNumber": 18,
      "leftText": "కొనడం చావడం",
      "rightNumber": 15,
      "rightText": "23 అడ్డం పాతరూపాయి"
    },
    {
      "leftNumber": 20,
      "leftText": "చంద్రునిది ఆయుధం",
      "rightNumber": 18,
      "rightText": "దక్షిణానికి గౌతమీనది"
    },
    {
      "leftNumber": 22,
