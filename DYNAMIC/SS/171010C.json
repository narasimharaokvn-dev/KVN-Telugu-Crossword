{
  "sheetName": "171010",
  "identity": "171010C",
  "rows": [
    {
      "leftNumber": 2,
      "leftText": "10 నిలువు! గాంధీ శిష్యుడు 1 నిలువు కోరుతాడు.",
      "rightNumber": 1,
      "rightText": "చూడు"
    },
    {
      "leftNumber": 5,
      "leftText": "ఒక నది ఒక రైల్వే స్టేషన్",
      "rightNumber": 2,
      "rightText": null
    },
    {
      "leftNumber": 7,
      "leftText": "(1971 లో) మన రాష్ట్రపతి",
      "rightNumber": 10,
      "rightText": null
    },
    {
      "leftNumber": 9,
      "leftText": "ద్రాక్షపళ్ళ విమర్శకుడు",
      "rightNumber": 2,
      "rightText": "పువ్వు ఆకారం లేని ఆవిరి"
    },
    {
      "leftNumber": 11,
      "leftText": "తిరగేస్తే జంతువు ఇంగ్లీషులో ఆలస్యం",
      "rightNumber": 3,
      "rightText": "వంగ పెరట్లో మాత్రం కాదు"
    },
    {
      "leftNumber": 12,
      "leftText": "సర్వనామము",
      "rightNumber": 4,
      "rightText": "23 నిలువు. బుచ్చిబాబు నవల"
    },
    {
      "leftNumber": 13,
      "leftText": "దక్షిణ గంగ",
      "rightNumber": 6,
      "rightText": "ఇది లేకుంటే విడాకులే!"
    },
    {
      "leftNumber": 15,
      "leftText": "టీ కలిపితే వెలుగిచ్చే స్వర్గం",
      "rightNumber": 8,
      "rightText": "ఖరీదైన లోహం"
    },
    {
      "leftNumber": 17,
      "leftText": "18 కోసం (ఎలుక కోసం కూడా)",
      "rightNumber": 10,
      "rightText": "చూడు 2 అడ్డం"
    },
    {
      "leftNumber": 18,
      "leftText": "పుట్ర, కాదు దాని ముందు ఉండేది.",
      "rightNumber": 12,
      "rightText": "ప్రాచీనాభరణం"
    },
    {
      "leftNumber": 19,
      "leftText": "కవలలలో ఒకడు",
      "rightNumber": 13,
      "rightText": "బహుమతి"
    },
    {
      "leftNumber": 21,
      "leftText": "కవలలు స్వప్నాలు కావడానికి ఒక అక్షరమే అడ్డు",
      "rightNumber": 14,
      "rightText": "శత్రులు"
    },
    {
      "leftNumber": 23,
      "leftText": "చితికిన బ్రతుకులకు చివరిగతి మొదటే ఉంది",
      "rightNumber": 16,
      "rightText": "మనవి, విజ్ఞాపన"
    },
    {
      "leftNumber": 24,
      "leftText": "అరవనాణెం ఆకారమా?",
      "rightNumber": 20,
      "rightText": "మనుచరిత్రలో సైన్యం"
    },
    {
      "leftNumber": 26,
      "leftText": "తన కవసరమైన దానిలో 2",
      "rightNumber": 22,
      "rightText": "భారతంలో ఇల్లు"
    },
    {
      "leftNumber": 27,
      "leftText": "సభకు తలకట్టు",
      "rightNumber": 23,
      "rightText": "చూడు 4 నిలువు"
    },
    {
      "leftNumber": 29,
      "leftText": "ఇబ్సెన్ నాటకం",
      "rightNumber": 25,
      "rightText": "కంట్లోనూ ఇంట్లోనూ ఉంటుంది"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 26,
      "rightText": "కులం ఉత్తరం"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 28,
      "rightText": "దకాలు చేరిస్తే నువ్వుల నీళ్ళు"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 30,
      "rightText": "పెరుమాళ్ళ కెరుక!"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 29,
      "rightText": "తిలకం, నాణెం, బిందువు"
    }
  ],
