{
  "sheetName": "200745",
  "identity": "200745C",
  "rows": [
    {
      "leftNumber": 3,
      "leftText": "మర్యాదస్తుడు అసమాపక క్రియ",
      "rightNumber": 1,
      "rightText": "నీటిలో సాహసం"
    },
    {
      "leftNumber": 5,
      "leftText": "– ఆడేది పోటీ",
      "rightNumber": 2,
      "rightText": "గురుతుగా వాత"
    },
    {
      "leftNumber": 7,
      "leftText": "నిద్రకి పచ్చజెండా",
      "rightNumber": 3,
      "rightText": "రౌతు కొద్దీ ఇది"
    },
    {
      "leftNumber": 9,
      "leftText": "సరిగ",
      "rightNumber": 4,
      "rightText": "బోయలు స్వర్గవాసులు"
    },
    {
      "leftNumber": 10,
      "leftText": "పళ్ళకీ కొమ్మలకీ",
      "rightNumber": 5,
      "rightText": "జనం"
    },
    {
      "leftNumber": 12,
      "leftText": "చీమలశ్రమ",
      "rightNumber": 6,
      "rightText": "జిహ్వ కొకటి"
    },
    {
      "leftNumber": 13,
      "leftText": "లంచం ?",
      "rightNumber": 7,
      "rightText": "మీదకు చూడు"
    },
    {
      "leftNumber": 15,
      "leftText": "ఆహ్వానించు",
      "rightNumber": 8,
      "rightText": "లేదంటే స్పురించలేదు"
    },
    {
      "leftNumber": 16,
      "leftText": "చెట్టు వెళ్ళడం",
      "rightNumber": 11,
      "rightText": "విశ్వాసమే లక్ష్యం"
    },
    {
      "leftNumber": 17,
      "leftText": "పై",
      "rightNumber": 14,
      "rightText": "అమ్మకపు చోట్లు"
    },
    {
      "leftNumber": 20,
      "leftText": "శక్తి రెండు స్వరాలు",
      "rightNumber": 15,
      "rightText": "తరువాత"
    },
    {
      "leftNumber": 2,
      "leftText": "కచ్చా ?",
      "rightNumber": 18,
      "rightText": "ప్రత్యక్షం"
    },
    {
      "leftNumber": 23,
      "leftText": "భూదాన గ్రహీత",
      "rightNumber": 19,
      "rightText": "దయం ఉదయం"
    },
    {
      "leftNumber": 25,
      "leftText": "నీ, నా",
      "rightNumber": 21,
      "rightText": "ప్రతిజ్ఞలు"
    },
    {
      "leftNumber": 27,
      "leftText": "అతిధులకు",
      "rightNumber": 22,
      "rightText": "మసతో తడబాటు"
    },
    {
      "leftNumber": 29,
      "leftText": "సమాధ్యవస్థలు",
      "rightNumber": 23,
      "rightText": "మంచి – కాడెప్పుడూ 11 తప్పుడు"
    },
    {
      "leftNumber": 31,
      "leftText": "టాలు ఏకవచనమే",
      "rightNumber": 24,
      "rightText": "ఉభయచరం"
    },
    {
      "leftNumber": 32,
      "leftText": "హాకీలో గమ్యం",
      "rightNumber": 26,
      "rightText": "చదరం గీతలు సమానం"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 28,
      "rightText": "మారుతిప్పుడు లేరు"
    },
    {
      "leftNumber": null,
      "leftText": null,
      "rightNumber": 30,
      "rightText": "(తురకల) సమాధి"
    }
  ],
